<%- include('partials/header', { title: 'Nouvelle soumission', page: 'soumissions' }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-plus-circle"></i> Nouvelle soumission</h2>
  <a href="/soumissions" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Retour</a>
</div>

<div class="row justify-content-center">
  <div class="col-md-8">
    <form method="POST" action="/soumissions/nouveau" enctype="multipart/form-data" id="formSoumission">
      <input type="hidden" name="numero" value="<%= numero %>">

      <!-- Upload devis -->
      <div class="card mb-3">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0"><i class="bi bi-upload"></i> Importer le devis (optionnel)</h5>
        </div>
        <div class="card-body">
          <input type="file" name="devis" class="form-control" accept=".pdf,.xlsx,.xls">
          <div class="form-text">Si vous importez le devis, toutes les informations seront extraites automatiquement (client, projet, quantités, etc.)</div>
        </div>
      </div>

      <!-- Essentiel uniquement -->
      <div class="card mb-3">
        <div class="card-header bg-dark text-white">
          <h5 class="mb-0"><i class="bi bi-gear"></i> Informations essentielles</h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label fw-bold">Système de toiture *</label>
              <select name="systeme_toiture" class="form-select" required id="selSysteme">
                <option value="">-- Sélectionner --</option>
                <% systemes.forEach(s => { %>
                <option value="<%= s.value %>"><%= s.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Type de travaux *</label>
              <select name="type_travaux" class="form-select" required id="selTravaux">
                <option value="">-- Sélectionner --</option>
                <% types_travaux.forEach(t => { %>
                <option value="<%= t.value %>"><%= t.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Prix total ($) *</label>
              <input type="number" name="prix_total" class="form-control" step="0.01" required placeholder="150000">
            </div>
          </div>
          <div class="row g-3 mt-1">
            <div class="col-md-6">
              <label class="form-label fw-bold">Nom du client *</label>
              <input type="text" name="client_nom" class="form-control" required placeholder="Ex: Syndicat de copropriété ABC">
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">Langue</label>
              <select name="langue" class="form-select">
                <option value="FR">Français</option>
                <option value="EN">Anglais</option>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">Numéro</label>
              <input type="text" class="form-control" value="<%= numero %>" readonly>
            </div>
          </div>
        </div>
      </div>

      <!-- Template détecté -->
      <div class="alert alert-info d-none" id="templatePreview">
        <i class="bi bi-file-earmark-word"></i>
        <strong>Template :</strong> <span id="templateName"></span>
      </div>

      <div class="d-flex gap-3 mb-4">
        <button type="submit" class="btn btn-primary btn-lg" id="btnCreer">
          <i class="bi bi-magic"></i> Créer la soumission
        </button>
        <a href="/soumissions" class="btn btn-outline-secondary btn-lg">Annuler</a>
      </div>
    </form>
  </div>
</div>

<script>
  var selSysteme = document.getElementById('selSysteme');
  var selTravaux = document.getElementById('selTravaux');
  var preview = document.getElementById('templatePreview');
  var templateName = document.getElementById('templateName');

  function updateTemplatePreview() {
    var s = selSysteme.value;
    var t = selTravaux.value;
    if (!s || !t) { preview.classList.add('d-none'); return; }
    fetch('/soumissions/api/template-preview?systeme=' + encodeURIComponent(s) + '&type_travaux=' + encodeURIComponent(t))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.found) {
          templateName.textContent = data.label;
          preview.classList.remove('d-none');
        } else {
          preview.classList.add('d-none');
        }
      });
  }

  selSysteme.addEventListener('change', updateTemplatePreview);
  selTravaux.addEventListener('change', updateTemplatePreview);

  document.getElementById('formSoumission').addEventListener('submit', function() {
    var btn = document.getElementById('btnCreer');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Création en cours...';
  });
</script>

<%- include('partials/footer', { scripts: [] }) %>

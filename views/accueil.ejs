<%- include('partials/header', { title: 'Accueil', page: 'accueil' }) %>

<div class="hero text-center">
  <h1><i class="bi bi-building"></i> Toitures 3 Étoiles</h1>
  <p>Interface de gestion documentaire et bordereaux techniques</p>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-3">
    <a href="/connaissances" class="text-decoration-none">
      <div class="card stat-card text-center p-4">
        <div class="stat-icon text-primary"><i class="bi bi-book"></i></div>
        <h3 class="mt-2"><%= stats.documents %></h3>
        <p class="text-muted mb-0">Documents</p>
      </div>
    </a>
  </div>
  <div class="col-md-3">
    <a href="/connaissances?tab=materiaux" class="text-decoration-none">
      <div class="card stat-card text-center p-4">
        <div class="stat-icon text-success"><i class="bi bi-box-seam"></i></div>
        <h3 class="mt-2"><%= stats.materiaux %></h3>
        <p class="text-muted mb-0">Matériaux</p>
        <small class="text-muted"><%= stats.fichestechniques %> fiches techniques</small>
      </div>
    </a>
  </div>
  <div class="col-md-3">
    <a href="/bordereaux" class="text-decoration-none">
      <div class="card stat-card text-center p-4">
        <div class="stat-icon text-warning"><i class="bi bi-file-earmark-text"></i></div>
        <h3 class="mt-2"><%= stats.bordereaux %></h3>
        <p class="text-muted mb-0">Bordereaux</p>
      </div>
    </a>
  </div>
  <div class="col-md-3">
    <a href="/connaissances?tab=architectes" class="text-decoration-none">
      <div class="card stat-card text-center p-4">
        <div class="stat-icon text-info"><i class="bi bi-people"></i></div>
        <h3 class="mt-2"><%= stats.architectes %></h3>
        <p class="text-muted mb-0">Architectes</p>
      </div>
    </a>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-book text-primary"></i> Base de connaissances</h5>
        <p class="card-text">Consultez, ajoutez ou retirez des documents techniques : bulletins AMCQ, codes du bâtiment, fiches matériaux, devis types.</p>
        <a href="/connaissances" class="btn btn-primary">Accéder</a>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-file-earmark-text text-warning"></i> Bordereaux techniques</h5>
        <p class="card-text">Importez un bordereau vide, remplissez-le avec les données du devis et de la base de connaissances, ajoutez les fiches techniques.</p>
        <a href="/bordereaux/nouveau" class="btn btn-warning">Nouveau bordereau</a>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-check-circle text-success"></i> Approbation</h5>
        <p class="card-text">Gérez le cycle d'approbation des bordereaux : Brouillon → Révisé → Approuvé, puis téléchargez le PDF final.</p>
        <a href="/approbation" class="btn btn-success">Gérer</a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer', { scripts: [] }) %>

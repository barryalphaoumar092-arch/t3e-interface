<%- include('partials/header', { title: 'Éditer bordereau', page: 'bordereaux' }) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/bordereaux">Bordereaux</a></li>
    <li class="breadcrumb-item active">Éditer #<%= bordereau.id %></li>
  </ol>
</nav>

<div class="row">
  <!-- COLONNE PRINCIPALE -->
  <div class="col-md-8">
    <form method="POST" action="/bordereaux/sauvegarder/<%= bordereau.id %>" id="formEdit">

      <!-- Infos projet -->
      <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h5 class="mb-0"><i class="bi bi-building"></i> Informations du projet</h5>
          <span class="badge badge-<%= bordereau.statut %>" style="font-size: 1rem;"><%= bordereau.statut.charAt(0).toUpperCase() + bordereau.statut.slice(1) %></span>
        </div>
        <div class="card-body">
          <% var readonly = bordereau.statut === 'approuve' ? 'readonly' : ''; %>
          <% var projet = bordereau.contenu.projet || {}; %>
          <div class="row mb-2">
            <div class="col-md-4">
              <label class="form-label">Numéro de projet</label>
              <input type="text" name="numero_projet" class="form-control" value="<%= projet.numero || bordereau.numero_projet || '' %>" <%= readonly %>>
            </div>
            <div class="col-md-8">
              <label class="form-label">Titre</label>
              <input type="text" name="titre" class="form-control" value="<%= bordereau.titre %>" <%= readonly %>>
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-md-4">
              <label class="form-label">Client</label>
              <input type="text" name="client" class="form-control" value="<%= projet.client || '' %>" <%= readonly %>>
            </div>
            <div class="col-md-4">
              <label class="form-label">Architecte</label>
              <input type="text" name="architecte" class="form-control" value="<%= projet.architecte || '' %>" <%= readonly %>>
            </div>
            <div class="col-md-4">
              <label class="form-label">Adresse</label>
              <input type="text" name="adresse" class="form-control" value="<%= projet.adresse || '' %>" <%= readonly %>>
            </div>
          </div>
        </div>
      </div>

      <!-- Matériaux trouvés automatiquement -->
      <% var materiaux = bordereau.contenu.materiaux_matches || []; %>
      <% if (materiaux.length > 0) { %>
      <div class="card mb-3">
        <div class="card-header bg-info text-white">
          <h5 class="mb-0"><i class="bi bi-box-seam"></i> Matériaux détectés dans le devis</h5>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
              <thead class="table-light">
                <tr><th>Produit</th><th>Fabricant</th><th>Type</th><th>Score</th></tr>
              </thead>
              <tbody>
                <% materiaux.forEach(function(m) { %>
                <tr>
                  <td><%= m.nom || '' %></td>
                  <td><%= m.fabricant || '' %></td>
                  <td><span class="badge bg-secondary"><%= m.type_produit || '' %></span></td>
                  <td>
                    <% var sc = m.score >= 60 ? 'success' : m.score >= 30 ? 'warning' : 'danger'; %>
                    <span class="badge bg-<%= sc %>"><%= m.score || 0 %></span>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% } %>

      <!-- SÉLECTION DES FICHES TECHNIQUES -->
      <div class="card mb-3">
        <div class="card-header bg-success text-white">
          <h5 class="mb-0"><i class="bi bi-file-earmark-pdf"></i> Sélectionner les fiches techniques à joindre</h5>
        </div>
        <div class="card-body">
          <p class="text-muted mb-2">Sélectionnez les fiches techniques qui seront ajoutées à la suite du bordereau dans le PDF final.</p>

          <div class="mb-3">
            <input type="text" id="searchFT" class="form-control" placeholder="Rechercher une fiche technique...">
          </div>

          <% var fichesSelect = bordereau.contenu.fiches_selectionnees || []; %>
          <% var fichesIds = fichesSelect.map(function(f) { return f.id; }); %>

          <div id="selectedFT" class="mb-3">
            <% if (fichesSelect.length > 0) { %>
            <h6><i class="bi bi-check-circle text-success"></i> Fiches sélectionnées (<span id="countFT"><%= fichesSelect.length %></span>)</h6>
            <div class="list-group mb-2" id="selectedList">
              <% fichesSelect.forEach(function(f) { %>
              <div class="list-group-item d-flex justify-content-between align-items-center selected-ft" data-id="<%= f.id %>" data-titre="<%= f.titre %>" data-fichier="<%= f.nom_fichier %>" data-chemin="<%= f.chemin_fichier %>" data-source="<%= f.source %>">
                <span><i class="bi bi-file-pdf text-danger"></i> <strong><%= f.titre %></strong> <small class="text-muted">(<%= f.source %>)</small></span>
                <button type="button" class="btn btn-sm btn-outline-danger btn-remove-ft"><i class="bi bi-x"></i></button>
              </div>
              <% }) %>
            </div>
            <% } else { %>
            <h6><i class="bi bi-info-circle"></i> Aucune fiche sélectionnée — <span id="countFT">0</span></h6>
            <div class="list-group mb-2" id="selectedList"></div>
            <% } %>
          </div>

          <h6>Base de connaissances — Fiches techniques disponibles</h6>
          <div style="max-height:400px;overflow-y:auto;" id="ftList">
            <% var currentSource = ''; %>
            <% ftDocs.forEach(function(doc) { %>
              <% if (doc.source !== currentSource) { currentSource = doc.source; %>
                <div class="ft-group fw-bold text-primary mt-2 mb-1"><%= doc.source || 'Autre' %></div>
              <% } %>
              <div class="ft-item d-flex justify-content-between align-items-center border-bottom py-1 px-2" data-search="<%= (doc.titre + ' ' + doc.source + ' ' + doc.nom_fichier).toLowerCase() %>" data-id="<%= doc.id %>" data-titre="<%= doc.titre %>" data-fichier="<%= doc.nom_fichier %>" data-chemin="<%= doc.chemin_fichier %>" data-source="<%= doc.source %>">
                <span class="small">
                  <i class="bi bi-file-pdf text-danger"></i> <%= doc.titre %>
                  <small class="text-muted">(<%= doc.nom_fichier %>)</small>
                </span>
                <button type="button" class="btn btn-sm btn-outline-success btn-add-ft <%= fichesIds.indexOf(doc.id) >= 0 ? 'd-none' : '' %>"><i class="bi bi-plus"></i></button>
              </div>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Devis (pliable) -->
      <% if (bordereau.contenu.devis) { %>
      <div class="card mb-3">
        <div class="card-header" style="cursor:pointer" data-bs-toggle="collapse" data-bs-target="#collapseDevis">
          <i class="bi bi-file-earmark-text"></i> Devis : <strong><%= bordereau.contenu.devis.source_fichier || '' %></strong>
          <i class="bi bi-chevron-down float-end"></i>
        </div>
        <div class="collapse" id="collapseDevis">
          <div class="card-body">
            <% if (bordereau.contenu.devis.tables && bordereau.contenu.devis.tables.length > 0) { %>
              <% bordereau.contenu.devis.tables.forEach(function(table) { %>
                <div class="table-responsive" style="max-height:250px;overflow-y:auto;">
                  <table class="table table-sm table-bordered">
                    <thead><tr><% (table.colonnes || []).forEach(function(c) { %><th><%= c %></th><% }) %></tr></thead>
                    <tbody><% (table.donnees || []).slice(0,50).forEach(function(row) { %><tr><% (table.colonnes || []).forEach(function(c) { %><td><%= row[c] || '' %></td><% }) %></tr><% }) %></tbody>
                  </table>
                </div>
              <% }) %>
            <% } %>
            <% if (bordereau.contenu.devis.texte_preview) { %>
              <pre style="max-height:150px;overflow-y:auto;font-size:0.75rem;background:#f8f9fa;padding:10px;border-radius:4px;white-space:pre-wrap;"><%= bordereau.contenu.devis.texte_preview %></pre>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Template (pliable) -->
      <% if (bordereau.contenu.template) { %>
      <div class="card mb-3">
        <div class="card-header" style="cursor:pointer" data-bs-toggle="collapse" data-bs-target="#collapseTemplate">
          <i class="bi bi-file-earmark-word"></i> Modèle bordereau : <strong><%= bordereau.contenu.template.source_fichier || '' %></strong>
          <i class="bi bi-chevron-down float-end"></i>
        </div>
        <div class="collapse" id="collapseTemplate">
          <div class="card-body">
            <% if (bordereau.contenu.template.texte_preview) { %>
              <pre style="max-height:150px;overflow-y:auto;font-size:0.75rem;background:#f8f9fa;padding:10px;border-radius:4px;white-space:pre-wrap;"><%= bordereau.contenu.template.texte_preview %></pre>
            <% } %>
          </div>
        </div>
      </div>
      <% } %>

      <input type="hidden" name="materiaux_json" id="materiauxJson" value='<%= JSON.stringify(materiaux) %>'>
      <input type="hidden" name="fiches_json" id="fichesJson" value='<%= JSON.stringify(bordereau.contenu.fiches_selectionnees || []) %>'>

      <% if (bordereau.statut !== 'approuve') { %>
      <div class="d-flex gap-2 mb-3">
        <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-save"></i> Sauvegarder</button>
        <button type="submit" formaction="/bordereaux/generer-pdf/<%= bordereau.id %>" class="btn btn-success btn-lg"><i class="bi bi-file-pdf"></i> Télécharger PDF</button>
      </div>
      <% } else { %>
      <button type="submit" formaction="/bordereaux/generer-pdf/<%= bordereau.id %>" class="btn btn-success btn-lg mb-3"><i class="bi bi-file-pdf"></i> Télécharger PDF</button>
      <% } %>

    </form>
  </div>

  <!-- SIDEBAR -->
  <div class="col-md-4">
    <div class="card mb-3">
      <div class="card-header"><h6 class="mb-0"><i class="bi bi-bar-chart"></i> Résumé</h6></div>
      <div class="card-body">
        <div class="d-flex justify-content-between mb-1"><span>Matériaux détectés</span><strong><%= materiaux.length %></strong></div>
        <div class="d-flex justify-content-between mb-1"><span>Fiches techniques jointes</span><strong class="text-success" id="statFT"><%= (bordereau.contenu.fiches_selectionnees || []).length %></strong></div>
        <% if (bordereau.template_fichier) { %>
        <div class="d-flex justify-content-between"><span>Template</span><strong class="text-primary"><%= bordereau.template_fichier %></strong></div>
        <% } %>
      </div>
    </div>

    <div class="card mb-3">
      <div class="card-header"><h6 class="mb-0">Cycle d'approbation</h6></div>
      <div class="card-body">
        <div class="status-timeline mb-3">
          <span class="status-step <%= bordereau.statut === 'brouillon' ? 'active bg-secondary' : 'inactive' %>">Brouillon</span>
          <span class="status-arrow"><i class="bi bi-arrow-right"></i></span>
          <span class="status-step <%= bordereau.statut === 'revise' ? 'active bg-warning' : 'inactive' %>">Révisé</span>
          <span class="status-arrow"><i class="bi bi-arrow-right"></i></span>
          <span class="status-step <%= bordereau.statut === 'approuve' ? 'active bg-success' : 'inactive' %>">Approuvé</span>
        </div>
        <% if (bordereau.statut === 'brouillon') { %>
        <form method="POST" action="/approbation/changer-statut/<%= bordereau.id %>">
          <input type="hidden" name="nouveau_statut" value="revise">
          <input type="text" name="effectue_par" class="form-control mb-2" placeholder="Révisé par...">
          <input type="text" name="commentaire" class="form-control mb-2" placeholder="Commentaire">
          <button type="submit" class="btn btn-warning w-100"><i class="bi bi-eye"></i> Marquer comme Révisé</button>
        </form>
        <% } else if (bordereau.statut === 'revise') { %>
        <form method="POST" action="/approbation/changer-statut/<%= bordereau.id %>">
          <input type="hidden" name="nouveau_statut" value="approuve">
          <input type="text" name="effectue_par" class="form-control mb-2" placeholder="Approuvé par...">
          <input type="text" name="commentaire" class="form-control mb-2" placeholder="Commentaire">
          <button type="submit" class="btn btn-success w-100"><i class="bi bi-check-circle"></i> Approuver</button>
        </form>
        <% } else { %>
        <div class="alert alert-success mb-0"><i class="bi bi-check-circle"></i> Approuvé.</div>
        <% } %>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><h6 class="mb-0">Historique</h6></div>
      <ul class="list-group list-group-flush">
        <% historique.forEach(function(h) { %>
        <li class="list-group-item py-1">
          <small class="text-muted"><%= h.date %></small><br>
          <strong><%= h.par %></strong> : <%= h.action %>
          <% if (h.nouveau) { %><span class="badge badge-<%= h.nouveau %>"><%= h.nouveau %></span><% } %>
          <% if (h.commentaire) { %><br><small><%= h.commentaire %></small><% } %>
        </li>
        <% }) %>
        <% if (historique.length === 0) { %>
        <li class="list-group-item text-muted">Aucun historique</li>
        <% } %>
      </ul>
    </div>
  </div>
</div>

<script>
var fichesSelectionnees = <%= JSON.stringify(bordereau.contenu.fiches_selectionnees || []) %>;

function updateFichesHidden() {
  document.getElementById('fichesJson').value = JSON.stringify(fichesSelectionnees);
  document.getElementById('countFT').textContent = fichesSelectionnees.length;
  document.getElementById('statFT').textContent = fichesSelectionnees.length;
}

function renderSelected() {
  var list = document.getElementById('selectedList');
  list.innerHTML = '';
  fichesSelectionnees.forEach(function(f, i) {
    var div = document.createElement('div');
    div.className = 'list-group-item d-flex justify-content-between align-items-center';
    div.innerHTML = '<span><i class="bi bi-file-pdf text-danger"></i> <strong>' + f.titre + '</strong> <small class="text-muted">(' + (f.source||'') + ')</small></span>' +
      '<button type="button" class="btn btn-sm btn-outline-danger btn-remove-ft" data-idx="' + i + '"><i class="bi bi-x"></i></button>';
    list.appendChild(div);
  });
  list.querySelectorAll('.btn-remove-ft').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var idx = parseInt(this.dataset.idx);
      var removedId = fichesSelectionnees[idx].id;
      fichesSelectionnees.splice(idx, 1);
      renderSelected();
      updateFichesHidden();
      var addBtn = document.querySelector('.ft-item[data-id="' + removedId + '"] .btn-add-ft');
      if (addBtn) addBtn.classList.remove('d-none');
    });
  });
  updateFichesHidden();
}

document.querySelectorAll('.btn-add-ft').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var item = this.closest('.ft-item');
    fichesSelectionnees.push({
      id: parseInt(item.dataset.id),
      titre: item.dataset.titre,
      nom_fichier: item.dataset.fichier,
      chemin_fichier: item.dataset.chemin,
      source: item.dataset.source
    });
    this.classList.add('d-none');
    renderSelected();
  });
});

document.querySelectorAll('.btn-remove-ft').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var idx = parseInt(this.dataset.idx);
    if (isNaN(idx)) {
      var item = this.closest('.selected-ft');
      if (item) {
        var id = parseInt(item.dataset.id);
        fichesSelectionnees = fichesSelectionnees.filter(function(f) { return f.id !== id; });
        var addBtn = document.querySelector('.ft-item[data-id="' + id + '"] .btn-add-ft');
        if (addBtn) addBtn.classList.remove('d-none');
      }
    } else {
      var removedId = fichesSelectionnees[idx].id;
      fichesSelectionnees.splice(idx, 1);
      var addBtn = document.querySelector('.ft-item[data-id="' + removedId + '"] .btn-add-ft');
      if (addBtn) addBtn.classList.remove('d-none');
    }
    renderSelected();
  });
});

document.getElementById('searchFT').addEventListener('input', function() {
  var q = this.value.toLowerCase();
  document.querySelectorAll('.ft-item').forEach(function(item) {
    item.style.display = item.dataset.search.includes(q) ? '' : 'none';
  });
  document.querySelectorAll('.ft-group').forEach(function(g) { g.style.display = q ? 'none' : ''; });
});

updateFichesHidden();
</script>

<%- include('partials/footer', { scripts: [] }) %>

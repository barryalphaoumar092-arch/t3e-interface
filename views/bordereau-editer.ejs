<%- include('partials/header', { title: 'Bordereau #' + bordereau.id + ' — ' + bordereau.titre, page: 'bordereaux' }) %>

<style>
  .field-overlay {
    position: absolute; cursor: move; font-size: 10px; color: #000080;
    font-weight: bold; padding: 1px 3px; border: 1px dashed transparent;
    white-space: nowrap; z-index: 10; user-select: none;
  }
  .field-overlay:hover { border-color: #dc3545; background: rgba(255,255,0,0.4); }
  .ft-selected { background: #d4edda; border-radius: 4px; padding: 3px 8px; margin: 2px 0; font-size: 0.75rem; display: flex; justify-content: space-between; align-items: center; }
</style>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/bordereaux">Bordereaux</a></li>
    <li class="breadcrumb-item active">#<%= bordereau.id %> — <%= bordereau.titre %></li>
  </ol>
</nav>

<div class="row g-2">

  <!-- ====== PANNEAU GAUCHE ====== -->
  <div class="col-md-3" style="max-height:92vh;overflow-y:auto;">

    <% if (!hasTemplate) { %>
    <!-- Pas de template : panneau upload prominent -->
    <div class="card mb-2 border-danger">
      <div class="card-header bg-danger text-white py-2">
        <i class="bi bi-exclamation-triangle"></i> <strong>Template PDF requis</strong>
      </div>
      <div class="card-body py-2 px-2">
        <p class="text-muted small mb-2">Uploadez le bordereau PDF vierge T3E pour commencer.</p>
        <input type="file" id="templateFile" accept=".pdf" class="form-control form-control-sm mb-1">
        <button type="button" class="btn btn-danger btn-sm w-100" id="btnUploadTemplate">
          <i class="bi bi-cloud-upload"></i> Charger le template PDF
        </button>
        <div id="uploadTemplateStatus" class="mt-1" style="font-size:0.75rem;"></div>
      </div>
    </div>
    <% } %>

    <!-- Bouton principal IA -->
    <div class="card mb-2 border-primary">
      <div class="card-body py-3 px-2 text-center">
        <% if (iaActive && hasTemplate) { %>
          <button type="button" class="btn btn-primary w-100 py-2" id="btnIAComplet" style="font-size:1rem;">
            <i class="bi bi-robot"></i><br>
            <strong>Analyser et générer le PDF</strong><br>
            <small class="opacity-75">IA remplit tout automatiquement</small>
          </button>
        <% } else if (!hasTemplate) { %>
          <button class="btn btn-secondary w-100 py-2" disabled>
            <i class="bi bi-robot"></i><br>
            <span>Chargez d'abord le template PDF</span>
          </button>
        <% } else { %>
          <button class="btn btn-secondary w-100 py-2" disabled>
            <i class="bi bi-robot"></i><br>
            <span>IA non configurée</span><br>
            <small>Ajoutez OPENAI_API_KEY sur Render</small>
          </button>
        <% } %>
        <div id="iaStatus" class="mt-2" style="font-size:0.8rem;"></div>
      </div>
    </div>

    <!-- Fiches techniques (optionnel — l'IA en sélectionne aussi) -->
    <div class="card mb-2">
      <div class="card-header bg-success text-white py-1 d-flex justify-content-between align-items-center">
        <small class="fw-bold"><i class="bi bi-file-pdf"></i> Fiches techniques</small>
        <span class="badge bg-light text-dark" id="countFT">0</span>
      </div>
      <div class="card-body py-2 px-2">
        <p class="text-muted" style="font-size:0.7rem;margin-bottom:4px;">L'IA sélectionne automatiquement les fiches pertinentes. Vous pouvez en ajouter manuellement.</p>
        <input type="text" id="searchFT" class="form-control form-control-sm mb-1" placeholder="Rechercher une fiche...">
        <div id="selectedFTList" class="mb-1"></div>
        <div style="max-height:200px;overflow-y:auto;font-size:0.7rem;" id="ftList">
          <% var currentSource = ''; %>
          <% ftDocs.forEach(function(doc) { %>
            <% if (doc.source !== currentSource) { currentSource = doc.source; %>
              <div class="ft-group fw-bold text-primary mt-1 px-1"><%= doc.source || 'Autre' %></div>
            <% } %>
            <div class="ft-item d-flex justify-content-between align-items-center py-0 px-1"
              data-search="<%= (doc.titre + ' ' + doc.source).toLowerCase() %>"
              data-id="<%= doc.id %>" data-titre="<%= doc.titre %>"
              data-fichier="<%= doc.nom_fichier %>" data-chemin="<%= doc.chemin_fichier %>" data-source="<%= doc.source %>">
              <span class="text-truncate"><i class="bi bi-file-pdf text-danger"></i> <%= doc.titre %></span>
              <button type="button" class="btn btn-outline-success btn-sm py-0 px-1 btn-add-ft flex-shrink-0" style="font-size:0.65rem">+</button>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Bouton télécharger le PDF déjà sauvegardé -->
    <div class="d-grid gap-1 mb-2">
      <a href="/bordereaux/generer-pdf-get/<%= bordereau.id %>" class="btn btn-outline-success btn-sm">
        <i class="bi bi-file-pdf"></i> Télécharger PDF (positions sauvegardées)
      </a>
    </div>

    <!-- Changer le template PDF (avancé) -->
    <div class="card mb-2 border-warning">
      <div class="card-header bg-warning text-dark py-1" style="cursor:pointer" id="toggleTemplate">
        <small class="fw-bold"><i class="bi bi-upload"></i> Changer le template PDF</small>
        <i class="bi bi-chevron-down float-end" id="templateChevron"></i>
      </div>
      <div class="card-body py-2 px-2 d-none" id="templateUploadZone">
        <p class="text-muted" style="font-size:0.75rem;">Remplacer le bordereau PDF vierge T3E.</p>
        <input type="file" id="templateFileChange" accept=".pdf" class="form-control form-control-sm mb-1">
        <button type="button" class="btn btn-warning btn-sm w-100" id="btnUploadTemplateChange">
          <i class="bi bi-cloud-upload"></i> Uploader le nouveau PDF
        </button>
        <div id="uploadTemplateStatusChange" class="mt-1" style="font-size:0.75rem;"></div>
      </div>
    </div>

  </div>

  <!-- ====== PANNEAU DROIT : APERÇU PDF ====== -->
  <div class="col-md-9">
    <div class="card">
      <div class="card-header py-1 d-flex justify-content-between align-items-center">
        <small class="fw-bold">
          <i class="bi bi-eye"></i> Aperçu du bordereau template
          <% if (hasTemplate) { %><span class="badge bg-success ms-1">PDF chargé</span><% } else { %><span class="badge bg-danger ms-1">Aucun template</span><% } %>
        </small>
        <small class="text-muted">Les positions des champs peuvent être ajustées par glisser-déposer</small>
      </div>
      <div class="card-body p-1">
        <div id="pdfContainer" style="position:relative;background:#f8f9fa;min-height:200px;">
          <% if (!hasTemplate) { %>
          <div class="p-5 text-center text-muted">
            <i class="bi bi-file-earmark-pdf" style="font-size:4rem;color:#dc3545;opacity:0.5;"></i>
            <p class="mt-3 fw-bold text-danger">Aucun template PDF chargé</p>
            <p>Utilisez le panneau rouge "<strong>Template PDF requis</strong>" à gauche<br>pour uploader le bordereau PDF vierge T3E.</p>
          </div>
          <% } else { %>
          <canvas id="pdfCanvas" style="width:100%;display:block;"></canvas>
          <div id="overlay" style="position:absolute;top:0;left:0;width:100%;height:100%;z-index:10;pointer-events:none;"></div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<% if (hasTemplate) { %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<% } %>
<script>
if (typeof pdfjsLib !== 'undefined') pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

// ============ Fiches techniques ============
var fichesSelectionnees = <%= JSON.stringify((bordereau.contenu.fiches_selectionnees || []).map(function(f){return{id:f.id,titre:f.titre,nom_fichier:f.nom_fichier,chemin_fichier:f.chemin_fichier,source:f.source};})) %>;
var savedPositions = <%= JSON.stringify(bordereau.contenu.field_positions || {}) %>;

function updateFT() {
  var list = document.getElementById('selectedFTList');
  var count = document.getElementById('countFT');
  list.innerHTML = '';
  fichesSelectionnees.forEach(function(f) {
    var div = document.createElement('div');
    div.className = 'ft-selected';
    div.innerHTML = '<span class="text-truncate"><i class="bi bi-file-pdf text-danger"></i> ' + f.titre + '</span>'
      + '<button type="button" class="btn btn-sm btn-outline-danger py-0 px-1 ms-1 flex-shrink-0" style="font-size:0.65rem" onclick="removeFT(' + f.id + ')">×</button>';
    list.appendChild(div);
  });
  count.textContent = fichesSelectionnees.length;
}

function removeFT(id) {
  fichesSelectionnees = fichesSelectionnees.filter(function(f) { return f.id !== id; });
  updateFT();
}

document.querySelectorAll('.btn-add-ft').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var item = this.closest('.ft-item');
    if (fichesSelectionnees.some(function(f) { return f.id === parseInt(item.dataset.id); })) return;
    fichesSelectionnees.push({ id: parseInt(item.dataset.id), titre: item.dataset.titre, nom_fichier: item.dataset.fichier, chemin_fichier: item.dataset.chemin, source: item.dataset.source });
    updateFT();
  });
});

document.getElementById('searchFT').addEventListener('input', function() {
  var q = this.value.toLowerCase();
  document.querySelectorAll('.ft-item').forEach(function(i) { i.style.display = i.dataset.search.includes(q) ? '' : 'none'; });
  document.querySelectorAll('.ft-group').forEach(function(g) { g.style.display = q ? 'none' : ''; });
});

updateFT();

// ============ Bouton principal IA complet ============
<% if (iaActive && hasTemplate) { %>
document.getElementById('btnIAComplet').addEventListener('click', function() {
  var btn = this;
  var status = document.getElementById('iaStatus');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span><br><strong>Analyse en cours...</strong><br><small>L\'IA lit le devis et remplit le bordereau</small>';
  status.innerHTML = '<div class="text-muted">Patientez ~10-20 secondes...</div>';

  var ficheIds = fichesSelectionnees.map(function(f) { return f.id; });

  fetch('/bordereaux/remplir-ia-complet/<%= bordereau.id %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ fiches_manuelles: ficheIds }),
    credentials: 'same-origin'
  })
  .then(function(r) {
    if (r.headers.get('content-type') && r.headers.get('content-type').includes('application/json')) {
      return r.json().then(function(data) { throw new Error(data.error || 'Erreur inconnue'); });
    }
    return r.blob();
  })
  .then(function(blob) {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-check-circle text-success" style="font-size:1.5rem;"></i><br><strong>PDF généré !</strong><br><small>Téléchargement en cours...</small>';
    status.innerHTML = '<div class="text-success"><i class="bi bi-check"></i> Succès — PDF rempli téléchargé</div>';
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url; a.download = 'bordereau-<%= bordereau.id %>-rempli.pdf'; a.click();
    URL.revokeObjectURL(url);
    setTimeout(function() {
      btn.innerHTML = '<i class="bi bi-robot"></i><br><strong>Analyser et générer le PDF</strong><br><small class="opacity-75">IA remplit tout automatiquement</small>';
      btn.disabled = false;
    }, 4000);
  })
  .catch(function(err) {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-robot"></i><br><strong>Analyser et générer le PDF</strong><br><small class="opacity-75">IA remplit tout automatiquement</small>';
    status.innerHTML = '<div class="text-danger"><i class="bi bi-exclamation-triangle"></i> ' + err.message + '</div>';
  });
});
<% } %>

// ============ Aperçu PDF (si template chargé) ============
<% if (hasTemplate) { %>
var containerEl = document.getElementById('pdfContainer');
var overlayEl   = document.getElementById('overlay');
var canvasW = 0, canvasH = 0;
var overlays = {};

function renderPdfPage(page) {
  var canvas = document.getElementById('pdfCanvas');
  var ctx = canvas.getContext('2d');
  var cw = containerEl.offsetWidth || containerEl.parentElement.offsetWidth || 800;
  if (cw < 100) cw = 800;
  var vp = page.getViewport({ scale: 1 });
  var scale = (cw * 2) / vp.width;
  var svp = page.getViewport({ scale: scale });
  canvas.width = svp.width; canvas.height = svp.height;
  var dh = Math.round(cw * vp.height / vp.width);
  canvas.style.width = cw + 'px'; canvas.style.height = dh + 'px';
  canvasW = cw; canvasH = dh;
  containerEl.style.height = dh + 'px';
  page.render({ canvasContext: ctx, viewport: svp }).promise.then(function() {
    restoreOverlays();
  });
}

pdfjsLib.getDocument({
  url: '/bordereaux/template-pdf/<%= bordereau.id %>',
  cMapUrl: 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/cmaps/',
  cMapPacked: true,
}).promise.then(function(pdf) {
  pdf.getPage(1).then(function(page) {
    setTimeout(function() { renderPdfPage(page); }, 400);
  });
}).catch(function() {
  containerEl.innerHTML = '<div class="p-5 text-center"><i class="bi bi-exclamation-triangle text-warning" style="font-size:3rem;"></i><p class="mt-3">Erreur de chargement du PDF. Essayez de re-charger le template.</p></div>';
});

// Afficher les positions sauvegardées comme overlays (pour calibration visuelle)
function addOverlay(key, label, val) {
  if (!val || !canvasW) return;
  if (overlays[key]) { overlays[key].el.textContent = val; return; }
  var div = document.createElement('div');
  div.className = 'field-overlay';
  div.textContent = val;
  div.title = label + ' — glisser pour repositionner';
  var defaultPos = {
    nom_du_projet:{x:27,y:16}, num_ro_du_projet:{x:29,y:18}, nom:{x:16,y:22.3},
    sp_cialit:{x:67,y:22.3}, adresse:{x:20,y:25.8}, ligne_num_ro:{x:82,y:32.2},
    titre:{x:18,y:38.4}, num_ro_de_dessins:{x:30,y:40.7}, nombre_feuilles:{x:63,y:40.7},
    r_vision:{x:83,y:40.7}, description:{x:24,y:42.6}, fournisseur:{x:25,y:44.7},
    fabricant:{x:59,y:44.7}, section_item:{x:65,y:47}, article:{x:58,y:49.2},
    d_lai:{x:18,y:51}, remarque:{x:24,y:54.5},
  };
  var rect = containerEl.getBoundingClientRect();
  var dp = savedPositions[key] || defaultPos[key] || { x: 40, y: 50 };
  div.style.left = (rect.width * dp.x / 100) + 'px';
  div.style.top = (rect.height * dp.y / 100) + 'px';
  div.style.pointerEvents = 'all';

  var dragging = false, ox, oy;
  div.addEventListener('mousedown', function(e) { e.preventDefault(); dragging = true; ox = e.clientX - div.offsetLeft; oy = e.clientY - div.offsetTop; });
  document.addEventListener('mousemove', function(e) { if (dragging) { div.style.left = (e.clientX-ox)+'px'; div.style.top = (e.clientY-oy)+'px'; } });
  document.addEventListener('mouseup', function() { if (dragging) { dragging = false; savePositions(); } });

  overlayEl.appendChild(div);
  overlays[key] = { el: div, val: val };
}

function savePositions() {
  var rect = containerEl.getBoundingClientRect();
  if (!rect.width) return;
  var pos = {};
  Object.keys(overlays).forEach(function(key) {
    var el = overlays[key].el;
    pos[key] = { x: (el.offsetLeft / rect.width) * 100, y: (el.offsetTop / rect.height) * 100, val: overlays[key].val, page: 0, size: 9 };
  });
  fetch('/bordereaux/sauvegarder-ajax/<%= bordereau.id %>', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ titre: '<%= bordereau.titre %>', positions: pos, positions_json: JSON.stringify(pos), fiches: fichesSelectionnees, fiches_json: JSON.stringify(fichesSelectionnees) }),
    credentials: 'same-origin'
  }).catch(function(){});
}

function restoreOverlays() {
  Object.keys(savedPositions).forEach(function(key) {
    var p = savedPositions[key];
    if (p && p.val) addOverlay(key, key, p.val);
  });
}
<% } %>

// ============ Upload template (bouton rouge si pas de template) ============
<% if (!hasTemplate) { %>
document.getElementById('btnUploadTemplate').addEventListener('click', function() { uploadTemplate('templateFile', 'uploadTemplateStatus', this); });
<% } %>

// ============ Changer template (panneau avancé) ============
document.getElementById('toggleTemplate').addEventListener('click', function() {
  var zone = document.getElementById('templateUploadZone');
  var chev = document.getElementById('templateChevron');
  zone.classList.toggle('d-none');
  chev.className = zone.classList.contains('d-none') ? 'bi bi-chevron-down float-end' : 'bi bi-chevron-up float-end';
});
document.getElementById('btnUploadTemplateChange').addEventListener('click', function() { uploadTemplate('templateFileChange', 'uploadTemplateStatusChange', this); });

function uploadTemplate(fileInputId, statusId, btn) {
  var file = document.getElementById(fileInputId).files[0];
  var status = document.getElementById(statusId);
  if (!file) { status.innerHTML = '<span class="text-danger">Choisissez un fichier PDF.</span>'; return; }
  var origLabel = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Upload...';
  status.innerHTML = '';
  var fd = new FormData();
  fd.append('template', file);
  fetch('/bordereaux/remplacer-template/<%= bordereau.id %>', { method: 'POST', body: fd, credentials: 'same-origin' })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      btn.disabled = false; btn.innerHTML = origLabel;
      if (res.error) { status.innerHTML = '<span class="text-danger">' + res.error + '</span>'; return; }
      status.innerHTML = '<span class="text-success"><i class="bi bi-check-circle"></i> ' + res.fichier + ' chargé (' + res.nb_champs + ' champs). Rechargement...</span>';
      setTimeout(function() { window.location.reload(); }, 1200);
    })
    .catch(function(err) { btn.disabled = false; btn.innerHTML = origLabel; status.innerHTML = '<span class="text-danger">Erreur : ' + err.message + '</span>'; });
}

// Initialiser les tooltips
document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function(el) { new bootstrap.Tooltip(el); });
</script>

<%- include('partials/footer', { scripts: [] }) %>

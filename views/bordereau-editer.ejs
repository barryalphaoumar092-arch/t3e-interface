<%- include('partials/header', { title: 'Éditer bordereau', page: 'bordereaux' }) %>

<style>
  .field-overlay {
    position: absolute; cursor: move; font-size: 11px; color: #0000cc;
    font-weight: bold; padding: 1px 4px; border: 1px dashed transparent;
    white-space: nowrap; z-index: 10; user-select: none;
  }
  .field-overlay:hover { border-color: red; background: rgba(255,255,0,0.3); }
  .field-select { font-size: 0.8rem; }
  .ft-selected { background: #d4edda; border-radius: 4px; padding: 4px 8px; margin: 2px 0; font-size: 0.75rem; }
</style>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/bordereaux">Bordereaux</a></li>
    <li class="breadcrumb-item active">#<%= bordereau.id %> — <%= bordereau.titre %></li>
  </ol>
</nav>

<div class="row">
  <!-- ========== GAUCHE : FORMULAIRE ========== -->
  <div class="col-md-4" style="max-height:92vh;overflow-y:auto;">
    <form method="POST" action="/bordereaux/sauvegarder/<%= bordereau.id %>" id="formEdit">

      <!-- Sélection des fiches techniques -->
      <div class="card mb-2">
        <div class="card-header bg-success text-white py-1">
          <small class="fw-bold">1. Sélectionner les fiches techniques</small>
          <span class="badge bg-light text-dark float-end" id="countFT">0</span>
        </div>
        <div class="card-body py-2 px-2">
          <input type="text" id="searchFT" class="form-control form-control-sm mb-1" placeholder="Rechercher...">
          <div id="selectedFTList"></div>
          <div style="max-height:150px;overflow-y:auto;font-size:0.7rem;" id="ftList">
            <% var currentSource = ''; %>
            <% ftDocs.forEach(function(doc) { %>
              <% if (doc.source !== currentSource) { currentSource = doc.source; %>
                <div class="ft-group fw-bold text-primary mt-1"><%= doc.source || 'Autre' %></div>
              <% } %>
              <div class="ft-item d-flex justify-content-between align-items-center py-0 px-1" data-search="<%= (doc.titre + ' ' + doc.source).toLowerCase() %>" data-id="<%= doc.id %>" data-titre="<%= doc.titre %>" data-fichier="<%= doc.nom_fichier %>" data-chemin="<%= doc.chemin_fichier %>" data-source="<%= doc.source %>">
                <span><i class="bi bi-file-pdf text-danger"></i> <%= doc.titre %></span>
                <button type="button" class="btn btn-outline-success btn-sm py-0 px-1 btn-add-ft" style="font-size:0.65rem">+</button>
              </div>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Champs du bordereau (extraits dynamiquement) -->
      <div class="card mb-2">
        <div class="card-header bg-primary text-white py-1">
          <small class="fw-bold">2. Remplir le bordereau</small>
        </div>
        <div class="card-body py-2 px-2" id="fieldsContainer">
          <% var fields = templateFields || []; %>
          <% if (fields.length === 0) { %>
            <p class="text-muted small">Aucun champ détecté. Soumettez un bordereau PDF pour voir les champs.</p>
          <% } %>
          <% fields.forEach(function(f) { %>
            <div class="mb-2">
              <label class="form-label fw-bold mb-0" style="font-size:0.75rem"><%= f.label %></label>
              <div class="d-flex gap-1">
                <select class="form-select form-select-sm field-select" data-field="<%= f.key %>" data-label="<%= f.label %>">
                  <option value="">— Choisir —</option>
                  <option value="__autre__">✏️ Autre</option>
                </select>
              </div>
              <input type="text" class="form-control form-control-sm mt-1 field-custom d-none" data-field="<%= f.key %>" data-label="<%= f.label %>" placeholder="Saisir...">
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Hidden data -->
      <input type="hidden" name="titre" value="<%= bordereau.titre %>">
      <input type="hidden" name="numero_projet" value="<%= bordereau.numero_projet || '' %>">
      <input type="hidden" name="client" value="<%= (bordereau.contenu.projet || {}).client || '' %>">
      <input type="hidden" name="adresse" value="<%= (bordereau.contenu.projet || {}).adresse || '' %>">
      <input type="hidden" name="architecte" value="<%= (bordereau.contenu.projet || {}).architecte || '' %>">
      <input type="hidden" name="fiches_json" id="fichesJson" value="[]">
      <input type="hidden" name="positions_json" id="positionsJson" value="{}">

      <!-- Boutons -->
      <div class="d-grid gap-1 mb-3">
        <button type="button" class="btn btn-primary btn-sm" id="btnSave"><i class="bi bi-save"></i> Sauvegarder</button>
        <button type="button" class="btn btn-success" id="btnPdf"><i class="bi bi-file-pdf"></i> Télécharger PDF</button>
      </div>
    </form>
  </div>

  <!-- ========== DROITE : APERÇU DU BORDEREAU ========== -->
  <div class="col-md-8">
    <div class="card">
      <div class="card-header py-1 d-flex justify-content-between">
        <small class="fw-bold">Aperçu — glissez le texte pour le positionner</small>
        <span class="badge bg-secondary"><%= bordereau.statut %></span>
      </div>
      <div class="card-body p-1">
        <div id="pdfContainer" style="position:relative;background:#fff;min-height:700px;height:85vh;">
          <embed id="pdfEmbed" src="/bordereaux/template-pdf/<%= bordereau.id %>#toolbar=0&navpanes=0" type="application/pdf" style="width:100%;height:100%;pointer-events:none;">
          <div id="overlay" style="position:absolute;top:0;left:0;width:100%;height:100%;z-index:10;"></div>
        </div>
        <!-- FT sélectionnées affichées en dessous -->
        <div id="ftPreview" class="mt-2"></div>
      </div>
    </div>
  </div>
</div>

<script>
var fichesSelectionnees = <%= JSON.stringify(bordereau.contenu.fiches_selectionnees || []) %>;
var savedPositions = <%= JSON.stringify(bordereau.contenu.field_positions || {}) %>;
var overlays = {};
var containerEl = document.getElementById('pdfContainer');
var overlayEl = document.getElementById('overlay');
// Forcer le conteneur au ratio LETTER (612x792) pour que positions = PDF
var cWidth = containerEl.clientWidth;
var pdfRatio = 792 / 612;
var cHeight = Math.round(cWidth * pdfRatio);
containerEl.style.height = cHeight + 'px';
var canvasW = cWidth;
var canvasH = cHeight;

setTimeout(function() {
  canvasW = containerEl.clientWidth;
  canvasH = containerEl.clientHeight;
  restoreSavedOverlays();
}, 500);

// ============ Créer un overlay draggable ============
function addOverlay(key, label, val) {
  // Recalculer les dimensions si nécessaire
  if (!canvasW || canvasW < 100) {
    canvasW = containerEl.clientWidth || 600;
    canvasH = containerEl.clientHeight || 800;
  }
  if (!val) return;
  if (overlays[key]) {
    overlays[key].el.textContent = val;
    overlays[key].val = val;
    savePositions();
    return;
  }

  var div = document.createElement('div');
  div.className = 'field-overlay';
  div.textContent = val;
  div.title = label + ' (glissez pour repositionner)';

  // Position : CENTRE du conteneur par défaut
  var rect = containerEl.getBoundingClientRect();
  var startX = rect.width * 0.4;
  var startY = rect.height * 0.5;

  // Restaurer la position sauvegardée si elle existe
  if (savedPositions[key]) {
    startX = (savedPositions[key].x / 100) * rect.width;
    startY = (savedPositions[key].y / 100) * rect.height;
  }

  div.style.left = startX + 'px';
  div.style.top = startY + 'px';

  // Drag
  var dragging = false, ox, oy;
  div.addEventListener('mousedown', function(e) {
    e.preventDefault();
    dragging = true;
    ox = e.clientX - div.offsetLeft;
    oy = e.clientY - div.offsetTop;
  });
  document.addEventListener('mousemove', function(e) {
    if (!dragging) return;
    div.style.left = (e.clientX - ox) + 'px';
    div.style.top = (e.clientY - oy) + 'px';
  });
  document.addEventListener('mouseup', function() {
    if (dragging) { dragging = false; savePositions(); }
  });

  overlayEl.appendChild(div);
  overlays[key] = { el: div, val: val };
  savePositions();
}

function removeOverlay(key) {
  if (overlays[key]) {
    overlays[key].el.remove();
    delete overlays[key];
    savePositions();
  }
}

function restoreSavedOverlays() {
  Object.keys(savedPositions).forEach(function(key) {
    var p = savedPositions[key];
    if (p && p.val) addOverlay(key, key, p.val);
  });
}

function savePositions() {
  var pos = {};
  var rect = containerEl.getBoundingClientRect();
  Object.keys(overlays).forEach(function(key) {
    var el = overlays[key].el;
    var elRect = el.getBoundingClientRect();
    pos[key] = {
      x: ((elRect.left - rect.left) / rect.width) * 100,
      y: ((elRect.top - rect.top) / rect.height) * 100,
      val: overlays[key].val
    };
  });
  document.getElementById('positionsJson').value = JSON.stringify(pos);
}

// ============ Dropdowns : charger suggestions ============
fetch('/bordereaux/suggestions/<%= bordereau.id %>').then(function(r) { return r.json(); }).then(function(sugg) {
  var allSuggestions = [];
  Object.values(sugg).forEach(function(arr) {
    if (Array.isArray(arr)) arr.forEach(function(v) { if (v) allSuggestions.push(v); });
  });
  allSuggestions = [...new Set(allSuggestions)];

  document.querySelectorAll('.field-select').forEach(function(sel) {
    var fieldKey = sel.dataset.field;
    var label = sel.dataset.label.toLowerCase();

    // Trouver les suggestions pertinentes pour ce champ
    var relevant = [];
    if (label.includes('projet') && label.includes('nom')) relevant = sugg.nom_projet || [];
    else if (label.includes('projet') && label.includes('num')) relevant = sugg.numero_projet || [];
    else if (label.includes('adresse')) relevant = sugg.adresse || [];
    else if (label.includes('architecte')) relevant = sugg.architecte || [];
    else if (label.includes('titre')) relevant = sugg.titre || [];
    else if (label.includes('description')) relevant = sugg.description || [];
    else if (label.includes('fournisseur')) relevant = sugg.fournisseur || [];
    else if (label.includes('fabricant')) relevant = sugg.fabricant || [];
    else relevant = allSuggestions;

    relevant = [...new Set(relevant.filter(Boolean))].slice(0, 20);

    // Insérer avant "Autre"
    var autreOpt = sel.querySelector('option[value="__autre__"]');
    relevant.forEach(function(v) {
      var opt = document.createElement('option');
      opt.value = v; opt.textContent = v;
      sel.insertBefore(opt, autreOpt);
    });

    // Restaurer la valeur sauvegardée
    var saved = savedPositions[fieldKey];
    if (saved && saved.val) {
      var found = false;
      for (var i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value === saved.val) { sel.selectedIndex = i; found = true; break; }
      }
      if (!found) {
        var customOpt = document.createElement('option');
        customOpt.value = saved.val; customOpt.textContent = saved.val; customOpt.selected = true;
        sel.insertBefore(customOpt, autreOpt);
      }
    }
  });
});

// ============ Événements dropdowns ============
document.querySelectorAll('.field-select').forEach(function(sel) {
  sel.addEventListener('change', function() {
    var key = this.dataset.field;
    var label = this.dataset.label;
    var customInput = this.parentElement.parentElement.querySelector('.field-custom');

    if (this.value === '__autre__') {
      customInput.classList.remove('d-none');
      customInput.focus();
      return;
    }
    customInput.classList.add('d-none');

    if (this.value) {
      addOverlay(key, label, this.value);
    } else {
      removeOverlay(key);
    }
  });
});

document.querySelectorAll('.field-custom').forEach(function(inp) {
  inp.addEventListener('input', function() {
    var key = this.dataset.field;
    var label = this.dataset.label;
    if (this.value) addOverlay(key, label, this.value);
    else removeOverlay(key);
  });
});

// ============ Fiches techniques ============
function updateFT() {
  document.getElementById('fichesJson').value = JSON.stringify(fichesSelectionnees);
  document.getElementById('countFT').textContent = fichesSelectionnees.length;

  var list = document.getElementById('selectedFTList');
  list.innerHTML = '';
  fichesSelectionnees.forEach(function(f, i) {
    var div = document.createElement('div');
    div.className = 'ft-selected d-flex justify-content-between align-items-center';
    div.innerHTML = '<span><i class="bi bi-check-circle text-success"></i> ' + f.titre + '</span><button type="button" class="btn btn-sm text-danger py-0" data-idx="' + i + '"><i class="bi bi-x"></i></button>';
    div.querySelector('button').addEventListener('click', function() {
      fichesSelectionnees.splice(i, 1); updateFT();
    });
    list.appendChild(div);
  });

  // Preview des FT sous le bordereau à droite — afficher les PDF
  var preview = document.getElementById('ftPreview');
  preview.innerHTML = '';
  fichesSelectionnees.forEach(function(f) {
    if (!f.chemin_fichier || !f.chemin_fichier.toLowerCase().endsWith('.pdf')) return;
    var pdfUrl = '/' + f.chemin_fichier;
    var section = document.createElement('div');
    section.className = 'mt-2';
    section.innerHTML = '<div class="d-flex justify-content-between align-items-center bg-light p-1 border"><small class="fw-bold"><i class="bi bi-file-pdf text-danger"></i> ' + f.titre + ' (' + (f.source||'') + ')</small></div>';
    var embed = document.createElement('embed');
    embed.src = pdfUrl + '#toolbar=0&navpanes=0';
    embed.type = 'application/pdf';
    embed.style.cssText = 'width:100%;height:600px;border:1px solid #ccc;';
    section.appendChild(embed);
    preview.appendChild(section);
  });
}
updateFT();

document.querySelectorAll('.btn-add-ft').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var item = this.closest('.ft-item');
    var already = fichesSelectionnees.some(function(f) { return f.id === parseInt(item.dataset.id); });
    if (already) return;
    fichesSelectionnees.push({
      id: parseInt(item.dataset.id), titre: item.dataset.titre,
      nom_fichier: item.dataset.fichier, chemin_fichier: item.dataset.chemin, source: item.dataset.source
    });
    updateFT();
  });
});

// Collecter toutes les données
function collectData() {
  savePositions();
  return {
    titre: '<%= bordereau.titre.replace(/'/g, "\\'") %>',
    numero_projet: '<%= (bordereau.numero_projet || '').replace(/'/g, "\\'") %>',
    client: '<%= ((bordereau.contenu.projet || {}).client || '').replace(/'/g, "\\'") %>',
    adresse: '<%= ((bordereau.contenu.projet || {}).adresse || '').replace(/'/g, "\\'") %>',
    architecte: '<%= ((bordereau.contenu.projet || {}).architecte || '').replace(/'/g, "\\'") %>',
    positions_json: document.getElementById('positionsJson').value,
    fiches_json: JSON.stringify(fichesSelectionnees),
  };
}

// Sauvegarder via AJAX
document.getElementById('btnSave').addEventListener('click', function() {
  var data = collectData();
  var btn = this;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Sauvegarde...';

  fetch('/bordereaux/sauvegarder-ajax/<%= bordereau.id %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  }).then(function(r) { return r.json(); }).then(function(res) {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-check-circle"></i> Sauvegardé !';
    btn.classList.replace('btn-primary', 'btn-success');
    setTimeout(function() {
      btn.innerHTML = '<i class="bi bi-save"></i> Sauvegarder';
      btn.classList.replace('btn-success', 'btn-primary');
    }, 2000);
  }).catch(function(err) {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-save"></i> Sauvegarder';
    alert('Erreur de sauvegarde: ' + err.message);
  });
});

// Télécharger PDF (sauvegarde d'abord puis télécharge)
document.getElementById('btnPdf').addEventListener('click', function() {
  var data = collectData();
  var btn = this;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Génération...';

  fetch('/bordereaux/sauvegarder-ajax/<%= bordereau.id %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  }).then(function() {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-file-pdf"></i> Télécharger PDF';
    window.location.href = '/bordereaux/generer-pdf-get/<%= bordereau.id %>';
  }).catch(function(err) {
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-file-pdf"></i> Télécharger PDF';
    alert('Erreur: ' + err.message);
  });
});

document.getElementById('searchFT').addEventListener('input', function() {
  var q = this.value.toLowerCase();
  document.querySelectorAll('.ft-item').forEach(function(item) { item.style.display = item.dataset.search.includes(q) ? '' : 'none'; });
  document.querySelectorAll('.ft-group').forEach(function(g) { g.style.display = q ? 'none' : ''; });
});
</script>

<%- include('partials/footer', { scripts: [] }) %>

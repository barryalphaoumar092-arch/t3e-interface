<%- include('partials/header', { title: 'Approbation', page: 'approbation' }) %>

<h2><i class="bi bi-check-circle"></i> Système d'approbation</h2>

<div class="row g-3 mb-4 mt-2">
  <div class="col-md-4">
    <a href="/approbation?statut=brouillon" class="text-decoration-none">
      <div class="card stat-card text-center p-3 <%= filtre === 'brouillon' ? 'border-secondary border-3' : '' %>">
        <div class="stat-icon text-secondary"><i class="bi bi-pencil"></i></div>
        <h3><%= counts.brouillon %></h3>
        <p class="mb-0">Brouillons</p>
      </div>
    </a>
  </div>
  <div class="col-md-4">
    <a href="/approbation?statut=revise" class="text-decoration-none">
      <div class="card stat-card text-center p-3 <%= filtre === 'revise' ? 'border-warning border-3' : '' %>">
        <div class="stat-icon text-warning"><i class="bi bi-eye"></i></div>
        <h3><%= counts.revise %></h3>
        <p class="mb-0">En révision</p>
      </div>
    </a>
  </div>
  <div class="col-md-4">
    <a href="/approbation?statut=approuve" class="text-decoration-none">
      <div class="card stat-card text-center p-3 <%= filtre === 'approuve' ? 'border-success border-3' : '' %>">
        <div class="stat-icon text-success"><i class="bi bi-check-circle"></i></div>
        <h3><%= counts.approuve %></h3>
        <p class="mb-0">Approuvés</p>
      </div>
    </a>
  </div>
</div>

<% if (filtre) { %>
<a href="/approbation" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-x"></i> Retirer le filtre</a>
<% } %>

<div class="table-responsive">
  <table class="table table-hover">
    <thead>
      <tr><th>#</th><th>Projet</th><th>Titre</th><th>Statut</th><th>Créé par</th><th>Révisé par</th><th>Approuvé par</th><th>Dernière MAJ</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% bordereaux.forEach(function(b) { %>
      <tr>
        <td><%= b.id %></td>
        <td><strong><%= b.numero_projet || '-' %></strong></td>
        <td><%= b.titre %></td>
        <td>
          <span class="badge badge-<%= b.statut %>">
            <%= b.statut.charAt(0).toUpperCase() + b.statut.slice(1) %>
          </span>
        </td>
        <td><%= b.cree_par || '-' %></td>
        <td><%= b.modifie_par || '-' %></td>
        <td><%= b.approuve_par || '-' %></td>
        <td><%= b.updated_at || '-' %></td>
        <td>
          <a href="/bordereaux/editer/<%= b.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
          <% if (b.statut === 'brouillon') { %>
          <form method="POST" action="/approbation/changer-statut/<%= b.id %>" class="d-inline">
            <input type="hidden" name="nouveau_statut" value="revise">
            <input type="hidden" name="effectue_par" value="Utilisateur">
            <button class="btn btn-sm btn-outline-warning" title="Passer en révision"><i class="bi bi-arrow-right"></i> Réviser</button>
          </form>
          <% } else if (b.statut === 'revise') { %>
          <form method="POST" action="/approbation/changer-statut/<%= b.id %>" class="d-inline">
            <input type="hidden" name="nouveau_statut" value="approuve">
            <input type="hidden" name="effectue_par" value="Utilisateur">
            <button class="btn btn-sm btn-outline-success" title="Approuver"><i class="bi bi-check"></i> Approuver</button>
          </form>
          <% } else { %>
          <a href="/bordereaux/generer-pdf-get/<%= b.id %>" class="btn btn-sm btn-success"><i class="bi bi-file-pdf"></i> PDF</a>
          <% } %>
        </td>
      </tr>
      <% }) %>
      <% if (bordereaux.length === 0) { %>
      <tr><td colspan="9" class="text-center text-muted py-4">Aucun bordereau dans cette catégorie</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('partials/footer', { scripts: [] }) %>

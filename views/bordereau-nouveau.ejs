<%- include('partials/header', { title: 'Nouveau bordereau', page: 'bordereaux' }) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/bordereaux">Bordereaux</a></li>
    <li class="breadcrumb-item active">Nouveau</li>
  </ol>
</nav>

<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card shadow-sm">
      <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-magic"></i> Remplir un bordereau automatiquement</h5>
      </div>
      <div class="card-body">

        <% if (typeof erreur !== 'undefined' && erreur) { %>
          <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> <%= erreur %></div>
        <% } %>

        <form method="POST" action="/bordereaux/generer" enctype="multipart/form-data" id="formGenerer">

          <!-- 1. Devis PDF -->
          <div class="mb-4">
            <label class="form-label fw-bold">
              <span class="badge bg-warning text-dark me-1">1</span>
              Devis du projet <span class="text-danger">*</span>
            </label>
            <input type="file" name="devis" class="form-control" accept=".pdf" required>
            <div class="form-text">Le devis du projet en PDF.</div>
          </div>

          <!-- 2. Bordereau à remplir -->
          <div class="mb-4">
            <label class="form-label fw-bold">
              <span class="badge bg-warning text-dark me-1">2</span>
              Bordereau à remplir <span class="text-danger">*</span>
            </label>
            <input type="file" name="bordereau" class="form-control" accept=".docx" required>
            <div class="form-text">Le bordereau vierge en format <strong>.docx</strong> (Word). Si votre bordereau est en <code>.doc</code>, ouvrez-le dans Word et sauvegardez-le en <code>.docx</code> d'abord.</div>
          </div>

          <!-- 3. Nom du projet (optionnel) -->
          <div class="mb-4">
            <label class="form-label fw-bold">
              <span class="badge bg-secondary me-1">3</span>
              Nom du projet <span class="text-muted fw-normal">(optionnel)</span>
            </label>
            <input type="text" name="nom_projet" class="form-control" placeholder="Ex: Réfection toiture Polytechnique Montréal">
            <div class="form-text">Laissez vide pour que l'IA l'extraie du devis automatiquement.</div>
          </div>

          <div class="d-grid">
            <button type="submit" class="btn btn-warning btn-lg" id="btnGenerer">
              <i class="bi bi-magic"></i> Générer le bordereau rempli
            </button>
          </div>
        </form>

      </div>
    </div>

    <div class="card mt-3 border-0 bg-light">
      <div class="card-body py-2 px-3">
        <small class="text-muted">
          <i class="bi bi-info-circle"></i>
          L'IA lit le devis, extrait les informations du projet et remplit automatiquement tous les champs du bordereau.
          Les champs fixes sont toujours pré-remplis : <strong>Toitures Trois Étoiles Inc.</strong>, <strong>Couvreur</strong>, adresse.
        </small>
      </div>
    </div>
  </div>
</div>

<script>
document.getElementById('formGenerer').addEventListener('submit', function() {
  var btn = document.getElementById('btnGenerer');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>L\'IA remplit le bordereau&hellip;';
});
</script>

<%- include('partials/footer', { scripts: [] }) %>

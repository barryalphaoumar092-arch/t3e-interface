<%- include('partials/header', { title: 'Nouveau bordereau', page: 'bordereaux' }) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/bordereaux">Bordereaux</a></li>
    <li class="breadcrumb-item active">Nouveau</li>
  </ol>
</nav>

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Créer un nouveau bordereau</h5>
      </div>
      <div class="card-body">
        <form method="POST" action="/bordereaux/creer" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">Numéro de projet</label>
            <input type="text" name="numero_projet" class="form-control" placeholder="Ex: EH26-0375">
          </div>
          <div class="mb-3">
            <label class="form-label">Titre du bordereau *</label>
            <input type="text" name="titre" class="form-control" required placeholder="Ex: Bordereau de transmission - Projet ABC">
          </div>
          <div class="mb-3">
            <label class="form-label">Créé par</label>
            <input type="text" name="cree_par" class="form-control" placeholder="Votre nom">
          </div>
          <hr>
          <div class="mb-3">
            <label class="form-label"><i class="bi bi-upload"></i> Importer un document source (optionnel)</label>
            <input type="file" name="fichier_source" class="form-control" accept=".xlsx,.xls,.csv">
            <div class="form-text">Importez un devis ou une fiche technique (.xlsx, .xls) pour remplir automatiquement le bordereau.</div>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning"><i class="bi bi-plus-circle"></i> Créer le bordereau</button>
            <a href="/bordereaux" class="btn btn-secondary">Annuler</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer', { scripts: [] }) %>

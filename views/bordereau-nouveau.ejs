<%- include('partials/header', { title: 'Nouveau bordereau', page: 'bordereaux' }) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/bordereaux">Bordereaux</a></li>
    <li class="breadcrumb-item active">Nouveau</li>
  </ol>
</nav>

<div class="row justify-content-center">
  <div class="col-md-8">

    <div class="d-flex gap-2 mb-3">
      <span class="badge bg-primary fs-6">1. Upload</span>
      <span class="badge bg-secondary fs-6">2. Révision</span>
      <span class="badge bg-secondary fs-6">3. Téléchargement</span>
    </div>

    <div class="card shadow-sm">
      <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-magic"></i> Remplir un bordereau avec l'IA</h5>
      </div>
      <div class="card-body">

        <form method="POST" action="/bordereaux/analyser" enctype="multipart/form-data" id="formUpload">

          <div class="mb-4">
            <label class="form-label fw-bold">
              <span class="badge bg-warning text-dark me-1">1</span>
              Devis du projet <span class="text-danger">*</span>
            </label>
            <input type="file" name="devis" class="form-control" accept=".pdf,.docx,.doc,.xlsx,.xls" required>
            <div class="form-text">L'IA va lire le devis et en extraire : nom du projet, numéro, section, article, matériaux.</div>
          </div>

          <div class="mb-4">
            <label class="form-label fw-bold">
              <span class="badge bg-warning text-dark me-1">2</span>
              Bordereau .docx à remplir <span class="text-danger">*</span>
            </label>
            <input type="file" name="bordereau" class="form-control" accept=".docx" required>
            <div class="form-text">Le template Word T3E. L'IA remplira les champs directement dedans.</div>
          </div>

          <div class="mb-4">
            <div class="card border-secondary">
              <div class="card-header bg-secondary bg-opacity-10 py-2">
                <span class="fw-bold"><span class="badge bg-secondary me-1">3</span> Identification entrepreneur (pré-rempli)</span>
              </div>
              <div class="card-body pb-2">
                <div class="row g-2">
                  <div class="col-md-6">
                    <label class="form-label form-label-sm fw-semibold">NOM</label>
                    <input type="text" name="nom_entrepreneur" class="form-control form-control-sm" value="Toitures Trois Étoiles">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label form-label-sm fw-semibold">SPÉCIALITÉ</label>
                    <input type="text" name="specialite" class="form-control form-control-sm" value="COUVREUR">
                  </div>
                  <div class="col-12">
                    <label class="form-label form-label-sm fw-semibold">ADRESSE</label>
                    <input type="text" name="adresse" class="form-control form-control-sm" value="7550 Rue Saint-Patrick, Montréal, QC H8N 1V1">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label form-label-sm fw-semibold">NOM DU PROJET <span class="text-muted fw-normal">(optionnel — l'IA l'extrait du devis)</span></label>
                    <input type="text" name="nom_projet" class="form-control form-control-sm" placeholder="Laissez vide pour extraction auto">
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="d-grid">
            <button type="submit" class="btn btn-warning btn-lg" id="btnAnalyser">
              <i class="bi bi-magic"></i> Analyser avec l'IA
            </button>
          </div>
        </form>

      </div>
    </div>

  </div>
</div>

<script>
document.getElementById('formUpload').addEventListener('submit', function() {
  var btn = document.getElementById('btnAnalyser');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>L\'IA analyse le devis…';
});
</script>

<%- include('partials/footer', { scripts: [] }) %>

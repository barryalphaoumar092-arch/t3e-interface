<%- include('partials/header', { title: 'Nouveau bordereau', page: 'bordereaux' }) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/bordereaux">Bordereaux</a></li>
    <li class="breadcrumb-item active">Nouveau</li>
  </ol>
</nav>

<div class="row justify-content-center">
  <div class="col-md-9">

    <div class="card mb-4">
      <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Créer un nouveau bordereau</h5>
      </div>
      <div class="card-body">
        <form method="POST" action="/bordereaux/creer" enctype="multipart/form-data" id="formCreer">

          <!-- Étape 1 : Devis -->
          <div class="card mb-3 border-primary">
            <div class="card-header bg-primary text-white">
              <strong>1.</strong> Importer le devis du projet
            </div>
            <div class="card-body">
              <input type="file" name="devis" class="form-control" accept=".pdf,.xlsx,.xls">
              <div class="form-text">Le devis ou la soumission du projet (PDF ou Excel). Le système en extraira les matériaux et les informations.</div>
            </div>
          </div>

          <!-- Étape 2 : Template bordereau -->
          <div class="card mb-3 border-success">
            <div class="card-header bg-success text-white">
              <strong>2.</strong> Importer le modèle de bordereau à remplir
            </div>
            <div class="card-body">
              <input type="file" name="template" class="form-control" accept=".doc,.docx,.pdf">
              <div class="form-text">Le modèle de bordereau technique spécifique à ce projet (Word ou PDF). Chaque projet peut avoir un modèle différent.</div>
            </div>
          </div>

          <!-- Étape 3 : Infos projet -->
          <div class="card mb-3 border-secondary">
            <div class="card-header bg-secondary text-white">
              <strong>3.</strong> Informations du projet
            </div>
            <div class="card-body">
              <div class="row mb-3">
                <div class="col-md-4">
                  <label class="form-label">Numéro de projet</label>
                  <input type="text" name="numero_projet" class="form-control" placeholder="Ex: EH26-0375">
                </div>
                <div class="col-md-8">
                  <label class="form-label">Titre du bordereau *</label>
                  <input type="text" name="titre" class="form-control" required placeholder="Ex: Bordereau de transmission - Projet ABC">
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">Créé par</label>
                <input type="text" name="cree_par" class="form-control" placeholder="Votre nom">
              </div>
            </div>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning btn-lg" id="btnCreer">
              <i class="bi bi-magic"></i> Créer et remplir automatiquement
            </button>
            <a href="/bordereaux" class="btn btn-secondary btn-lg">Annuler</a>
          </div>

        </form>
      </div>
    </div>

  </div>
</div>

<script>
document.getElementById('formCreer').addEventListener('submit', function() {
  var btn = document.getElementById('btnCreer');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Analyse en cours...';
});
</script>

<%- include('partials/footer', { scripts: [] }) %>

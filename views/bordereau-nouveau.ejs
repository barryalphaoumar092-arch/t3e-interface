<%- include('partials/header', { title: 'Nouveau bordereau', page: 'bordereaux' }) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/bordereaux">Bordereaux</a></li>
    <li class="breadcrumb-item active">Nouveau</li>
  </ol>
</nav>

<div class="row justify-content-center">
  <div class="col-md-8">

    <div class="d-flex gap-2 mb-3">
      <span class="badge bg-primary fs-6">1. Upload</span>
      <span class="badge bg-secondary fs-6">2. Révision</span>
      <span class="badge bg-secondary fs-6">3. Téléchargement</span>
    </div>

    <div class="card shadow-sm">
      <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-magic"></i> Remplir un bordereau avec l'IA</h5>
      </div>
      <div class="card-body">

        <form method="POST" action="/bordereaux/analyser" enctype="multipart/form-data" id="formUpload">

          <div class="mb-4">
            <label class="form-label fw-bold">
              <span class="badge bg-warning text-dark me-1">1</span>
              Devis du projet <span class="text-danger">*</span>
            </label>
            <input type="file" name="devis" class="form-control" accept=".pdf,.docx,.doc,.xlsx,.xls" required>
            <div class="form-text">L'IA va lire le devis et en extraire : nom du projet, numéro, section, article, matériaux.</div>
          </div>

          <div class="mb-4">
            <label class="form-label fw-bold">
              <span class="badge bg-warning text-dark me-1">2</span>
              Bordereau .docx à remplir <span class="text-danger">*</span>
            </label>
            <input type="file" name="bordereau" class="form-control" accept=".docx" required>
            <div class="form-text">Le template Word T3E. L'IA remplira les champs directement dedans.</div>
          </div>

          <div class="mb-4">
            <label class="form-label fw-bold">
              <span class="badge bg-warning text-dark me-1">3</span>
              Matériaux du bordereau <span class="text-danger">*</span>
            </label>
            <div class="position-relative">
              <input type="text" id="rechercheMateriau" class="form-control" placeholder="Rechercher un matériau (nom, fabricant)…" autocomplete="off">
              <div id="suggestionsMateriaux" class="list-group position-absolute w-100 shadow-sm" style="z-index: 1000; max-height: 320px; overflow-y: auto; display: none;"></div>
            </div>
            <div class="form-text">Recherchez et sélectionnez chaque matériau référencé dans ce devis. L'IA se chargera ensuite de trouver la section, l'article et la fiche technique de chacun.</div>
            <div id="materiauxSelectionnes" class="mt-2 d-flex flex-column gap-1"></div>
          </div>

          <div class="mb-4">
            <div class="card border-secondary">
              <div class="card-header bg-secondary bg-opacity-10 py-2">
                <span class="fw-bold"><span class="badge bg-secondary me-1">4</span> Identification entrepreneur (pré-rempli)</span>
              </div>
              <div class="card-body pb-2">
                <div class="row g-2">
                  <div class="col-md-6">
                    <label class="form-label form-label-sm fw-semibold">NOM</label>
                    <input type="text" name="nom_entrepreneur" class="form-control form-control-sm" value="Toitures Trois Étoiles">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label form-label-sm fw-semibold">SPÉCIALITÉ</label>
                    <input type="text" name="specialite" class="form-control form-control-sm" value="COUVREUR">
                  </div>
                  <div class="col-12">
                    <label class="form-label form-label-sm fw-semibold">ADRESSE</label>
                    <input type="text" name="adresse" class="form-control form-control-sm" value="7550 Rue Saint-Patrick, Montréal, QC H8N 1V1">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label form-label-sm fw-semibold">NOM DU PROJET <span class="text-muted fw-normal">(optionnel — l'IA l'extrait du devis)</span></label>
                    <input type="text" name="nom_projet" class="form-control form-control-sm" placeholder="Laissez vide pour extraction auto">
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="d-grid">
            <button type="submit" class="btn btn-warning btn-lg" id="btnAnalyser" disabled>
              <i class="bi bi-magic"></i> Sélectionnez au moins un matériau
            </button>
          </div>
        </form>

      </div>
    </div>

  </div>
</div>

<script>
var materiauxChoisis = [];
var searchInput = document.getElementById('rechercheMateriau');
var suggestionsBox = document.getElementById('suggestionsMateriaux');
var selectedBox = document.getElementById('materiauxSelectionnes');
var btnAnalyser = document.getElementById('btnAnalyser');
var debounceTimer = null;

function escapeHtml(s) {
  var d = document.createElement('div');
  d.textContent = s || '';
  return d.innerHTML;
}

searchInput.addEventListener('input', function() {
  clearTimeout(debounceTimer);
  var q = searchInput.value.trim();
  if (q.length < 2) { suggestionsBox.style.display = 'none'; suggestionsBox.innerHTML = ''; return; }
  debounceTimer = setTimeout(function() {
    fetch('/api/materiaux?q=' + encodeURIComponent(q))
      .then(function(r) { return r.json(); })
      .then(function(items) { afficherSuggestions(items); })
      .catch(function() { suggestionsBox.style.display = 'none'; });
  }, 250);
});

function afficherSuggestions(items) {
  if (!items || items.length === 0) {
    suggestionsBox.innerHTML = '<div class="list-group-item text-muted small">Aucun résultat</div>';
    suggestionsBox.style.display = 'block';
    return;
  }
  suggestionsBox.innerHTML = '';
  items.slice(0, 40).forEach(function(item) {
    var dejaChoisi = materiauxChoisis.some(function(m) { return m.id === item.id; });
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'list-group-item list-group-item-action' + (dejaChoisi ? ' disabled text-muted' : '');
    btn.innerHTML = '<strong>' + escapeHtml(item.nom) + '</strong>' +
      (item.fabricant ? ' <span class="text-muted small">— ' + escapeHtml(item.fabricant) + (item.fournisseur ? ' / ' + escapeHtml(item.fournisseur) : '') + '</span>' : '') +
      (dejaChoisi ? ' <i class="bi bi-check-circle text-success"></i>' : '');
    if (!dejaChoisi) {
      btn.addEventListener('click', function() { ajouterMateriau(item); });
    }
    suggestionsBox.appendChild(btn);
  });
  suggestionsBox.style.display = 'block';
}

function ajouterMateriau(item) {
  materiauxChoisis.push(item);
  rendreSelection();
  searchInput.value = '';
  suggestionsBox.style.display = 'none';
  searchInput.focus();
}

function retirerMateriau(id) {
  materiauxChoisis = materiauxChoisis.filter(function(m) { return m.id !== id; });
  rendreSelection();
}

function rendreSelection() {
  selectedBox.innerHTML = '';
  materiauxChoisis.forEach(function(item) {
    var row = document.createElement('div');
    row.className = 'd-flex justify-content-between align-items-center border rounded px-2 py-1 bg-light';
    row.innerHTML = '<span><i class="bi bi-box-seam text-primary me-1"></i><strong>' + escapeHtml(item.nom) + '</strong>' +
      (item.fabricant ? ' <span class="text-muted small">— ' + escapeHtml(item.fabricant) + '</span>' : '') + '</span>';

    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'btn btn-sm btn-outline-danger';
    btn.innerHTML = '<i class="bi bi-x-lg"></i>';
    btn.addEventListener('click', function() { retirerMateriau(item.id); });
    row.appendChild(btn);
    selectedBox.appendChild(row);

    var hidden = document.createElement('input');
    hidden.type = 'hidden';
    hidden.name = 'materiau_id';
    hidden.value = item.id;
    selectedBox.appendChild(hidden);
  });

  btnAnalyser.disabled = materiauxChoisis.length === 0;
  btnAnalyser.innerHTML = materiauxChoisis.length === 0
    ? '<i class="bi bi-magic"></i> Sélectionnez au moins un matériau'
    : '<i class="bi bi-magic"></i> Analyser avec l\'IA (' + materiauxChoisis.length + ' matériau' + (materiauxChoisis.length > 1 ? 'x' : '') + ')';
}

document.addEventListener('click', function(e) {
  if (!suggestionsBox.contains(e.target) && e.target !== searchInput) {
    suggestionsBox.style.display = 'none';
  }
});

document.getElementById('formUpload').addEventListener('submit', function() {
  btnAnalyser.disabled = true;
  btnAnalyser.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>L\'IA analyse le devis…';
});
</script>

<%- include('partials/footer', { scripts: [] }) %>

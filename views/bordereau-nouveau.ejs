<%- include('partials/header', { title: 'Nouveau bordereau', page: 'bordereaux' }) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/bordereaux">Bordereaux</a></li>
    <li class="breadcrumb-item active">Nouveau</li>
  </ol>
</nav>

<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card shadow-sm">
      <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-file-earmark-arrow-up"></i> Remplir un bordereau automatiquement</h5>
      </div>
      <div class="card-body">

        <% if (typeof erreur !== 'undefined' && erreur) { %>
          <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> <%= erreur %></div>
        <% } %>

        <p class="text-muted mb-4">
          Importez le devis PDF du projet — l'IA extrait les informations et remplit le bordereau T3E automatiquement.
          Vous téléchargez directement le <strong>.docx prêt à imprimer</strong>.
        </p>

        <form method="POST" action="/bordereaux/generer" enctype="multipart/form-data" id="formGenerer">

          <div class="mb-3">
            <label class="form-label fw-bold">Nom du projet <span class="text-muted fw-normal">(optionnel — l'IA le trouve dans le devis)</span></label>
            <input type="text" name="nom_projet" class="form-control" placeholder="Ex: Réfection toiture Polytechnique Montréal">
          </div>

          <div class="mb-4">
            <label class="form-label fw-bold">Devis PDF <span class="text-danger">*</span></label>
            <input type="file" name="devis" class="form-control" accept=".pdf,.xlsx,.xls" required>
            <div class="form-text">Le devis du projet (PDF de préférence).</div>
          </div>

          <div class="d-grid">
            <button type="submit" class="btn btn-warning btn-lg" id="btnGenerer">
              <i class="bi bi-magic"></i> Générer le bordereau
            </button>
          </div>
        </form>

      </div>
    </div>

    <div class="card mt-3 border-0 bg-light">
      <div class="card-body py-2 px-3">
        <small class="text-muted">
          <i class="bi bi-info-circle"></i>
          Le système utilise le template T3E officiel et remplit automatiquement :
          nom du projet, section, matériaux, fournisseur, fabricant, délai, remarques.
          Les champs fixes (entrepreneur, spécialité, adresse) sont toujours pré-remplis.
        </small>
      </div>
    </div>
  </div>
</div>

<script>
document.getElementById('formGenerer').addEventListener('submit', function() {
  var btn = document.getElementById('btnGenerer');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>L\'IA remplit le bordereau...';
});
</script>

<%- include('partials/footer', { scripts: [] }) %>

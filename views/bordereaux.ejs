<%- include('partials/header', { title: 'Bordereaux techniques', page: 'bordereaux' }) %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-file-earmark-text"></i> Bordereaux techniques</h2>
  <a href="/bordereaux/nouveau" class="btn btn-warning"><i class="bi bi-plus-circle"></i> Nouveau bordereau</a>
</div>

<div class="table-responsive">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr>
        <th>#</th>
        <th>Projet</th>
        <th>Section</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% bordereaux.forEach(function(b) { %>
      <tr>
        <td class="text-muted"><%= b.id %></td>
        <td><strong><%= b.titre || '-' %></strong></td>
        <td><span class="badge bg-secondary"><%= b.numero_projet || '-' %></span></td>
        <td><small class="text-muted"><%= b.created_at ? b.created_at.substring(0,10) : '-' %></small></td>
        <td>
          <a href="/bordereaux/telecharger/<%= b.id %>" class="btn btn-sm btn-outline-success" title="Télécharger .docx">
            <i class="bi bi-download"></i> .docx
          </a>
          <form method="POST" action="/bordereaux/supprimer/<%= b.id %>" style="display:inline" onsubmit="return confirm('Supprimer ce bordereau ?')">
            <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
              <i class="bi bi-trash"></i>
            </button>
          </form>
        </td>
      </tr>
      <% }) %>
      <% if (bordereaux.length === 0) { %>
      <tr><td colspan="5" class="text-center text-muted py-5">
        <i class="bi bi-inbox" style="font-size:3rem;display:block;margin-bottom:.5rem;"></i>
        Aucun bordereau généré.<br>
        <a href="/bordereaux/nouveau" class="btn btn-warning mt-3">
          <i class="bi bi-magic"></i> Générer votre premier bordereau
        </a>
      </td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('partials/footer', { scripts: [] }) %>

<%- include('partials/header', { title: 'Réviser les bordereaux', page: 'bordereaux' }) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/bordereaux">Bordereaux</a></li>
    <li class="breadcrumb-item active">Réviser</li>
  </ol>
</nav>

<div class="row justify-content-center">
  <div class="col-md-11">

    <div class="d-flex gap-2 mb-3">
      <span class="badge bg-success fs-6"><i class="bi bi-check"></i> 1. Upload</span>
      <span class="badge bg-primary fs-6">2. Révision</span>
      <span class="badge bg-secondary fs-6">3. Téléchargement</span>
    </div>

    <% if (iaErreur) { %>
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> L'IA n'a pas pu analyser le devis (<%= iaErreur %>). Remplissez les champs manuellement.</div>
    <% } else { %>
    <div class="alert alert-info mb-3"><i class="bi bi-robot"></i> L'IA a trouvé <strong><%= produits.length %> produit(s)</strong> dans le devis. Vérifiez et corrigez si nécessaire.</div>
    <% } %>

    <form method="POST" action="/bordereaux/generer/<%= bordereau.id %>" id="formGenerer">

      <!-- Identification (commun à tous les bordereaux) -->
      <div class="card mb-3">
        <div class="card-header bg-dark text-white py-2"><h6 class="mb-0"><i class="bi bi-building"></i> Identification (commun à tous)</h6></div>
        <div class="card-body">
          <div class="row g-2">
            <div class="col-md-5">
              <label class="form-label fw-bold">NOM DU PROJET</label>
              <input type="text" name="NOM_DU_PROJET" class="form-control" value="<%= champsCommuns.NOM_DU_PROJET || '' %>">
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">NUMÉRO DU PROJET</label>
              <input type="text" name="NUMERO_DU_PROJET" class="form-control" value="<%= champsCommuns.NUMERO_DU_PROJET || '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">NOM</label>
              <input type="text" name="NOM" class="form-control form-control-sm" value="<%= champsCommuns.NOM || 'Toitures Trois Étoiles' %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">SPÉCIALITÉ</label>
              <input type="text" name="SPECIALITE" class="form-control form-control-sm" value="<%= champsCommuns.SPECIALITE || 'COUVREUR' %>">
            </div>
            <div class="col-md-9">
              <label class="form-label">ADRESSE</label>
              <input type="text" name="ADRESSE" class="form-control form-control-sm" value="<%= champsCommuns.ADRESSE || '7550 Rue Saint-Patrick, Montréal, QC H8N 1V1' %>">
            </div>
          </div>
        </div>
      </div>

      <!-- Produits (1 bordereau par produit) -->
      <% produits.forEach(function(prod, i) { %>
      <div class="card mb-3 border-warning">
        <div class="card-header bg-warning text-dark py-2">
          <h6 class="mb-0"><i class="bi bi-file-earmark-text"></i> Bordereau <%= i + 1 %> — <%= prod.TITRE || 'Produit ' + (i+1) %></h6>
        </div>
        <div class="card-body">
          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label fw-bold">Titre (produit)</label>
              <input type="text" name="produits[<%= i %>][TITRE]" class="form-control" value="<%= prod.TITRE || '' %>">
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">Fabricant</label>
              <input type="text" name="produits[<%= i %>][FABRICANT]" class="form-control" value="<%= prod.FABRICANT || '' %>">
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">Fournisseur</label>
              <input type="text" name="produits[<%= i %>][FOURNISSEUR]" class="form-control" value="<%= prod.FOURNISSEUR || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Section</label>
              <input type="text" name="produits[<%= i %>][SECTION]" class="form-control form-control-sm" value="<%= prod.SECTION || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Article</label>
              <input type="text" name="produits[<%= i %>][ARTICLE]" class="form-control form-control-sm" value="<%= prod.ARTICLE || '' %>">
            </div>
            <div class="col-12">
              <label class="form-label">Remarque</label>
              <textarea name="produits[<%= i %>][REMARQUE]" class="form-control form-control-sm" rows="2"><%= prod.REMARQUE || '' %></textarea>
            </div>
          </div>
          <% if (ftParProduit[i] && ftParProduit[i].length > 0) { %>
          <div class="mt-2 p-2 bg-success bg-opacity-10 rounded">
            <small class="text-success fw-bold"><i class="bi bi-paperclip"></i> FT détectées :</small>
            <% ftParProduit[i].forEach(function(nom) { %>
            <small class="d-block text-muted"><i class="bi bi-file-pdf text-danger"></i> <%= nom %></small>
            <% }); %>
          </div>
          <% } %>
        </div>
      </div>
      <% }); %>

      <div class="d-flex gap-3 mb-4">
        <button type="submit" class="btn btn-success btn-lg" id="btnGenerer">
          <i class="bi bi-file-earmark-pdf"></i> Générer <%= produits.length %> bordereau(x) en 1 PDF
        </button>
        <a href="/bordereaux" class="btn btn-outline-secondary btn-lg">Annuler</a>
      </div>
    </form>

  </div>
</div>

<script>
document.getElementById('formGenerer').addEventListener('submit', function() {
  var btn = document.getElementById('btnGenerer');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Génération en cours (LibreOffice convertit chaque bordereau)...';
});
</script>

<%- include('partials/footer', { scripts: [] }) %>

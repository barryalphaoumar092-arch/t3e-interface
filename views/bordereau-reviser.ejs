<%- include('partials/header', { title: 'Réviser les bordereaux', page: 'bordereaux' }) %>

<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/bordereaux">Bordereaux</a></li>
    <li class="breadcrumb-item active">Réviser</li>
  </ol>
</nav>

<div class="row justify-content-center">
  <div class="col-md-11">

    <div class="d-flex gap-2 mb-3">
      <span class="badge bg-success fs-6"><i class="bi bi-check"></i> 1. Upload</span>
      <span class="badge bg-primary fs-6">2. Révision</span>
      <span class="badge bg-secondary fs-6">3. Téléchargement</span>
    </div>

    <% if (iaErreur) { %>
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> L'IA n'a pas pu analyser le devis (<%= iaErreur %>). Remplissez les champs manuellement.</div>
    <% } else { %>
    <div class="alert alert-info mb-3">
      <i class="bi bi-robot"></i> L'IA a détecté <strong><%= produits.length %></strong> produit<%= produits.length > 1 ? 's' : '' %>.
      Vérifiez et corrigez si nécessaire, puis cliquez sur <strong>Générer</strong>.
    </div>
    <% } %>

    <form method="POST" action="/bordereaux/generer/<%= bordereau.id %>" id="formGenerer">

      <!-- Identification commune -->
      <div class="card mb-3">
        <div class="card-header bg-dark text-white py-2">
          <h6 class="mb-0"><i class="bi bi-building"></i> Projet & Identification</h6>
        </div>
        <div class="card-body">
          <div class="row g-2">
            <div class="col-md-6">
              <label class="form-label fw-bold">NOM DU PROJET</label>
              <input type="text" name="NOM_DU_PROJET" class="form-control" value="<%= nomProjet %>">
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">NUMÉRO DU PROJET</label>
              <input type="text" name="NUMERO_DU_PROJET" class="form-control" value="<%= numProjet %>">
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">SPÉCIALITÉ</label>
              <input type="text" name="SPECIALITE" class="form-control" value="<%= identification.SPECIALITE || 'COUVREUR' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">NOM</label>
              <input type="text" name="NOM" class="form-control" value="<%= identification.NOM || 'Toitures Trois Étoiles' %>">
            </div>
            <div class="col-md-8">
              <label class="form-label fw-bold">ADRESSE</label>
              <input type="text" name="ADRESSE" class="form-control" value="<%= identification.ADRESSE || '7550 Rue Saint-Patrick, Montréal, QC H8N 1V1' %>">
            </div>
          </div>
        </div>
      </div>

      <!-- Produits (1 carte par produit) -->
      <div id="produitsContainer">
        <% produits.forEach(function(p, idx) { %>
        <div class="card mb-3 border-primary produit-card">
          <div class="card-header bg-primary bg-opacity-10 py-2 d-flex justify-content-between align-items-center">
            <h6 class="mb-0">
              <i class="bi bi-box-seam"></i> Produit <%= idx + 1 %>
              <% if (p.TITRE) { %><span class="text-muted ms-2">— <%= p.TITRE %></span><% } %>
            </h6>
            <button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('.produit-card').remove(); renum();" title="Supprimer">
              <i class="bi bi-trash"></i>
            </button>
          </div>
          <div class="card-body py-2">
            <div class="row g-2">
              <div class="col-md-5">
                <label class="form-label fw-bold">Titre (produit)</label>
                <input type="text" name="TITRE" class="form-control form-control-sm" value="<%= p.TITRE || '' %>">
              </div>
              <div class="col-md-3">
                <label class="form-label fw-bold">Fabricant</label>
                <input type="text" name="FABRICANT" class="form-control form-control-sm" value="<%= p.FABRICANT || '' %>">
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Fournisseur</label>
                <input type="text" name="FOURNISSEUR" class="form-control form-control-sm" value="<%= p.FOURNISSEUR || '' %>">
              </div>
              <div class="col-md-5">
                <label class="form-label">Section</label>
                <input type="text" name="SECTION" class="form-control form-control-sm" value="<%= p.SECTION || '' %>">
              </div>
              <div class="col-md-4">
                <label class="form-label">Article</label>
                <input type="text" name="ARTICLE" class="form-control form-control-sm" value="<%= p.ARTICLE || '' %>">
              </div>
              <div class="col-md-3">
                <% if (p.ft_noms && p.ft_noms.length > 0) { %>
                <label class="form-label">FT détectée</label>
                <div class="text-success small"><i class="bi bi-check-circle"></i> <%= p.ft_noms[0] %></div>
                <% } else { %>
                <label class="form-label">FT</label>
                <div class="text-muted small"><i class="bi bi-dash-circle"></i> Non trouvée</div>
                <% } %>
              </div>
              <div class="col-12">
                <label class="form-label">Remarque</label>
                <input type="text" name="REMARQUE" class="form-control form-control-sm" value="<%= p.REMARQUE || '' %>">
              </div>
            </div>
          </div>
        </div>
        <% }); %>
      </div>

      <div class="d-flex gap-3 mb-4">
        <button type="submit" class="btn btn-success btn-lg" id="btnGenerer">
          <i class="bi bi-file-earmark-zip"></i> Générer <%= produits.length %> bordereau<%= produits.length > 1 ? 'x' : '' %> + fiches techniques
        </button>
        <a href="/bordereaux" class="btn btn-outline-secondary btn-lg">Annuler</a>
      </div>
    </form>

  </div>
</div>

<script>
function renum() {
  document.querySelectorAll('.produit-card').forEach(function(card, i) {
    var h6 = card.querySelector('h6');
    var icon = '<i class="bi bi-box-seam"></i> Produit ' + (i + 1);
    var titre = card.querySelector('input[name="TITRE"]').value;
    if (titre) icon += '<span class="text-muted ms-2">— ' + titre + '</span>';
    h6.innerHTML = icon;
  });
  var n = document.querySelectorAll('.produit-card').length;
  var btn = document.getElementById('btnGenerer');
  btn.innerHTML = '<i class="bi bi-file-earmark-zip"></i> Générer ' + n + ' bordereau' + (n > 1 ? 'x' : '') + ' + fiches techniques';
}

document.getElementById('formGenerer').addEventListener('submit', function() {
  var btn = document.getElementById('btnGenerer');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Génération en cours…';
});
</script>

<%- include('partials/footer', { scripts: [] }) %>

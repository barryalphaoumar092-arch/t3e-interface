<%- include('partials/header', { title: 'Soumission — Étape 2 Validation | ' + soumission.systeme_toiture + ' | ' + soumission.client_nom, page: 'soumissions' }) %>

<div class="row justify-content-center">
  <div class="col-md-10">
    <div class="mb-4">
      <h2><i class="bi bi-check2-circle"></i> Valider les informations — <%= soumission.numero %></h2>
      <div class="d-flex gap-2 mt-2">
        <span class="badge bg-success fs-6"><i class="bi bi-check"></i> 1. Informations</span>
        <span class="badge bg-primary fs-6">2. Validation</span>
        <span class="badge bg-secondary fs-6">3. Génération</span>
      </div>
      <% if (iaActive) { %>
      <div class="alert alert-info mt-3 mb-0"><i class="bi bi-robot"></i> Les champs ci-dessous ont été pré-remplis par l'IA. Vérifiez et corrigez si nécessaire.</div>
      <% } %>
    </div>

    <form method="POST" action="/soumissions/<%= soumission.id %>/confirmer">

      <!-- Système de toiture -->
      <div class="card mb-3">
        <div class="card-header bg-warning text-dark"><h6 class="mb-0"><i class="bi bi-gear"></i> Système de toiture et template</h6></div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label fw-bold">Système de toiture *</label>
              <select name="systeme_toiture" class="form-select" required>
                <% systemes.forEach(s => { %>
                <option value="<%= s.value %>" <%= soumission.systeme_toiture===s.value?'selected':'' %>><%= s.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Type de travaux *</label>
              <select name="type_travaux" class="form-select" required>
                <% types_travaux.forEach(t => { %>
                <option value="<%= t.value %>" <%= soumission.type_travaux===t.value?'selected':'' %>><%= t.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label fw-bold">Langue</label>
              <select name="langue" class="form-select">
                <option value="FR" <%= soumission.langue==='FR'?'selected':'' %>>FR</option>
                <option value="EN" <%= soumission.langue==='EN'?'selected':'' %>>EN</option>
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label fw-bold">Type soumission</label>
              <select name="type_soumission" class="form-select">
                <% types_soumission.forEach(t => { %>
                <option value="<%= t.value %>" <%= soumission.type_soumission===t.value?'selected':'' %>><%= t.label %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-3">
        <!-- Client -->
        <div class="col-lg-6">
          <div class="card mb-3">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-person"></i> Client</h6></div>
            <div class="card-body">
              <div class="row g-2">
                <div class="col-12">
                  <label class="form-label">Nom *</label>
                  <input type="text" name="client_nom" class="form-control" value="<%= soumission.client_nom %>" required>
                </div>
                <div class="col-12">
                  <label class="form-label">Contact</label>
                  <input type="text" name="client_contact" class="form-control" value="<%= soumission.client_contact || '' %>">
                </div>
                <div class="col-8">
                  <label class="form-label">Adresse</label>
                  <input type="text" name="client_adresse" class="form-control" value="<%= soumission.client_adresse || '' %>">
                </div>
                <div class="col-4">
                  <label class="form-label">Ville</label>
                  <input type="text" name="client_ville" class="form-control" value="<%= soumission.client_ville || '' %>">
                </div>
                <div class="col-4">
                  <label class="form-label">Province</label>
                  <input type="text" name="client_province" class="form-control" value="<%= soumission.client_province || 'QC' %>">
                </div>
                <div class="col-4">
                  <label class="form-label">Code postal</label>
                  <input type="text" name="client_code_postal" class="form-control" value="<%= soumission.client_code_postal || '' %>">
                </div>
                <div class="col-6">
                  <label class="form-label">Téléphone</label>
                  <input type="tel" name="client_telephone" class="form-control" value="<%= soumission.client_telephone || '' %>">
                </div>
                <div class="col-6">
                  <label class="form-label">Courriel</label>
                  <input type="email" name="client_courriel" class="form-control" value="<%= soumission.client_courriel || '' %>">
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Projet -->
        <div class="col-lg-6">
          <div class="card mb-3">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-building"></i> Projet et quantités</h6></div>
            <div class="card-body">
              <div class="row g-2">
                <div class="col-6">
                  <label class="form-label">Nom du projet</label>
                  <input type="text" name="projet_nom" class="form-control" value="<%= soumission.projet_nom || '' %>">
                </div>
                <div class="col-6">
                  <label class="form-label">Adresse du projet</label>
                  <input type="text" name="projet_adresse" class="form-control" value="<%= soumission.projet_adresse || '' %>">
                </div>
                <div class="col-4">
                  <label class="form-label">Superficie (pi²)</label>
                  <input type="number" name="superficie_pc" class="form-control" value="<%= soumission.superficie_pc || '' %>">
                </div>
                <div class="col-4">
                  <label class="form-label">Pontage</label>
                  <select name="pontage" class="form-select">
                    <option value="">--</option>
                    <% pontages.forEach(p => { %>
                    <option value="<%= p.value %>" <%= soumission.pontage===p.value?'selected':'' %>><%= p.label %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="col-4">
                  <label class="form-label">Épaisseur isolant</label>
                  <input type="text" name="epaisseur_isolant" class="form-control" value="<%= soumission.epaisseur_isolant || '' %>">
                </div>
                <div class="col-3">
                  <label class="form-label">Drains</label>
                  <input type="number" name="nb_drains" class="form-control" value="<%= soumission.nb_drains || '' %>" min="0">
                </div>
                <div class="col-3">
                  <label class="form-label">Manchons év.</label>
                  <input type="number" name="nb_manchons_events" class="form-control" value="<%= soumission.nb_manchons_events || '' %>" min="0">
                </div>
                <div class="col-3">
                  <label class="form-label">Manchons ét.</label>
                  <input type="number" name="nb_manchons_etancheite" class="form-control" value="<%= soumission.nb_manchons_etancheite || '' %>" min="0">
                </div>
                <div class="col-3">
                  <label class="form-label">Cols cygne</label>
                  <input type="number" name="nb_cols_cygne" class="form-control" value="<%= soumission.nb_cols_cygne || '' %>" min="0">
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Prix et garantie -->
      <div class="card mb-3">
        <div class="card-header"><h6 class="mb-0"><i class="bi bi-currency-dollar"></i> Prix et garantie</h6></div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-3">
              <label class="form-label fw-bold">Prix total ($) *</label>
              <input type="number" name="prix_total" class="form-control" step="0.01" value="<%= soumission.prix_total || '' %>" required>
            </div>
            <div class="col-md-3">
              <label class="form-label">Garantie T3E</label>
              <select name="garantie_t3e" class="form-select">
                <% garanties_t3e.forEach(g => { %>
                <option value="<%= g.value %>" <%= soumission.garantie_t3e===g.value?'selected':'' %>><%= g.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label">Garantie manuf.</label>
              <select name="garantie_manufacturier" class="form-select">
                <% garanties_manuf.forEach(g => { %>
                <option value="<%= g.value %>" <%= soumission.garantie_manufacturier===g.value?'selected':'' %>><%= g.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label">Coût remp. CP ($/pi²)</label>
              <input type="text" name="cout_remplacement_cp" class="form-control" value="<%= soumission.cout_remplacement_cp || '' %>">
            </div>
          </div>
        </div>
      </div>

      <!-- Notes -->
      <div class="card mb-3">
        <div class="card-header"><h6 class="mb-0"><i class="bi bi-journal-text"></i> Notes et exclusions</h6></div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Exclusions spécifiques</label>
              <textarea name="exclusions_specifiques" class="form-control" rows="2"><%= soumission.exclusions_specifiques || '' %></textarea>
            </div>
            <div class="col-md-6">
              <label class="form-label">Notes internes</label>
              <textarea name="notes" class="form-control" rows="2"><%= soumission.notes || '' %></textarea>
            </div>
          </div>
        </div>
      </div>

      <div class="d-flex gap-3 mb-4">
        <button type="submit" class="btn btn-success btn-lg" id="btnConfirmer">
          <i class="bi bi-file-earmark-word"></i> Confirmer et générer le document
        </button>
        <a href="/soumissions" class="btn btn-outline-secondary btn-lg">Annuler</a>
      </div>
    </form>
  </div>
</div>

<script>
document.getElementById('btnConfirmer').closest('form').addEventListener('submit', function() {
  var btn = document.getElementById('btnConfirmer');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Génération en cours...';
});

// Vérifier les infos manquantes et poser les questions dans le chat
window.addEventListener('load', function() {
  if (!window.chatWidgetAPI) return;

  var questions = [];

  // Nom du client manquant
  var champNom = document.querySelector('[name="client_nom"]');
  if (champNom && (!champNom.value || champNom.value === 'Client sans nom')) {
    questions.push({
      texte: "Je n'ai pas trouvé le nom du client dans le devis. Quel est le nom du client ou de l'organisation ?",
      quickReplies: [],
      fieldTarget: 'client_nom',
      fieldLabel: 'Nom du client'
    });
  }

  // Superficie manquante
  var champSup = document.querySelector('[name="superficie_pc"]');
  if (champSup && !champSup.value) {
    questions.push({
      texte: "La superficie du toit n'est pas indiquée dans le devis. Quelle est la superficie approximative (en pieds carrés) ?",
      quickReplies: [
        { label: '< 5 000 pi²',    value: '4000',  fieldTarget: 'superficie_pc', fieldLabel: 'Superficie' },
        { label: '5 000 pi²',      value: '5000',  fieldTarget: 'superficie_pc', fieldLabel: 'Superficie' },
        { label: '10 000 pi²',     value: '10000', fieldTarget: 'superficie_pc', fieldLabel: 'Superficie' },
        { label: '20 000 pi²',     value: '20000', fieldTarget: 'superficie_pc', fieldLabel: 'Superficie' },
      ]
    });
  }

  // Système de toiture (BUR est le défaut — vérifier si c'était une valeur choisie ou un défaut)
  var champSys = document.querySelector('[name="systeme_toiture"]');
  var champTypeTrav = document.querySelector('[name="type_travaux"]');
  var iaInfoBanner = document.querySelector('.alert-info');

  // Si l'IA était active mais le système est BUR et il n'y a pas d'alerte IA → probablement une valeur par défaut
  <% if (!iaActive) { %>
  if (champSys && champSys.value === 'BUR' && champTypeTrav) {
    questions.push({
      texte: "Quel est le système de toiture pour ce projet ? (Je n'ai pas pu le détecter automatiquement)",
      quickReplies: [
        { label: 'BUR — Asphalte/Gravier',  value: 'BUR',               fieldTarget: 'systeme_toiture', fieldLabel: 'Système' },
        { label: 'Soprasmart',               value: 'SOPRASMART',        fieldTarget: 'systeme_toiture', fieldLabel: 'Système' },
        { label: 'Soprafix',                 value: 'SOPRAFIX',          fieldTarget: 'systeme_toiture', fieldLabel: 'Système' },
        { label: 'EPDM/PVC',                 value: 'EPDM_PVC',          fieldTarget: 'systeme_toiture', fieldLabel: 'Système' },
      ]
    });
  }
  <% } %>

  // Poser les questions avec un délai pour laisser le chat se charger
  if (questions.length > 0) {
    setTimeout(function() {
      // Poser les questions une à une avec délai
      questions.forEach(function(q, i) {
        setTimeout(function() {
          chatWidgetAPI.poserQuestion(q.texte, q.quickReplies);
        }, i * 800);
      });
    }, 1200);
  }
});
</script>

<%- include('partials/footer', { scripts: [] }) %>

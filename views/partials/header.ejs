<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - T3E Interface</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body data-chat-contexte="Page: <%= title %> | T3E Interface — soumissions et bordereaux de toiture commerciale, Québec">
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">
        <i class="bi bi-building"></i> T3E Interface
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link <%= page === 'accueil' ? 'active' : '' %>" href="/">
              <i class="bi bi-house"></i> Accueil
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= page === 'connaissances' ? 'active' : '' %>" href="/connaissances">
              <i class="bi bi-book"></i> Base de connaissances
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= page === 'soumissions' ? 'active' : '' %>" href="/soumissions">
              <i class="bi bi-file-earmark-ruled"></i> Soumissions
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= page === 'bordereaux' ? 'active' : '' %>" href="/bordereaux">
              <i class="bi bi-file-earmark-text"></i> Bordereaux
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= page === 'approbation' ? 'active' : '' %>" href="/approbation">
              <i class="bi bi-check-circle"></i> Approbation
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= page === 'recherche' ? 'active' : '' %>" href="/recherche">
              <i class="bi bi-search"></i> Recherche IA
            </a>
          </li>
        </ul>
        <span class="navbar-text text-light me-3">
          <i class="bi bi-person-circle"></i> Toitures 3 Étoiles
        </span>
        <a href="/logout" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-right"></i> Déconnexion</a>
      </div>
    </div>
  </nav>
  <main class="container-fluid mt-3">
